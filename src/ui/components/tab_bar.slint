import { Theme, AppI18n, LayoutConstants } from "../theme.slint";

export component TabBar inherits Rectangle {
    in property <[string]> tabs;
    in-out property <int> selected-index: 0;
    callback tab-clicked(int);
    height: 40px;
    background: Theme.content_bg;
    
    HorizontalLayout {
        padding: 0;
        spacing: 0;
        alignment: start;
        
        for tab[i] in root.tabs: Rectangle {
            height: 100%;
            min-width: 60px;
            background: tab-touch.pressed ? Theme.hover_bg : transparent;
            
            Rectangle {
                y: parent.height - 2px;
                width: 100%;
                height: 2px;
                background: root.selected-index == i ? Theme.accent : transparent;
            }
            
            tab-touch := TouchArea {
                clicked => {
                    root.selected-index = i;
                    root.tab-clicked(i);
                }
            }
            
            Text {
                text: tab;
                color: root.selected-index == i ? Theme.accent : Theme.text_secondary;
                font-family: Theme.default_font;
                font-size: 14px * LayoutConstants.font-scale;
                font-weight: root.selected-index == i ? 600 : 400;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: 100%;
                height: 100%;
            }
        }
    }
    
    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: Theme.border_color;
    }
}
