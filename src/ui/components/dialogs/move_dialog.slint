import { Theme, AppI18n, LayoutConstants } from "../../theme.slint";
import { CustomButton, CustomLineEdit } from "../form_widgets.slint";

export component MoveDialog inherits Rectangle {
    in property <bool> batch_move: false;
    in property <string> distro_name;
    in-out property <string> move_path;
    in property <string> error_msg;
    callback confirm(string);
    callback cancel();
    callback browse();
    in property <bool> enabled: true;
    background: #00000080;
    TouchArea { }

    Rectangle {
        width: 450px;
        height: 240px;
        background: Theme.card_bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.border_color;
        drop-shadow-blur: 16px;
        drop-shadow-color: #00000040;
        VerticalLayout {
            padding: 24px;
            spacing: 16px;
            Text {
                text: root.batch_move ? AppI18n.t("batch.move_title", [AppI18n.version]) : AppI18n.t("dialog.move_title", [root.distro_name, AppI18n.version]);
                font-size: 18px * LayoutConstants.font-scale;
                font-family: Theme.default_font;
                font-weight: 500;
                color: Theme.text_primary;
                horizontal-alignment: AppI18n.is-rtl ? right : left;
            }

            VerticalLayout {
                spacing: 8px;
                Text {
                    text: AppI18n.t("dialog.target_path", [AppI18n.version]) + ":";
                    font-size: 13px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    color: Theme.text_secondary;
                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                }

                HorizontalLayout {
                    spacing: 8px;
                    if (!AppI18n.is-rtl): Rectangle {
                        height: 32px;
                        horizontal-stretch: 1;
                        Rectangle {
                            visible: browse_touch.has-hover && path_text.preferred-width > path_text.width;
                            opacity: browse_touch.has-hover && path_text.preferred-width > path_text.width ? 1 : 0;
                            background: Theme.dark_mode ? #2D2D30 : #FFFFFF;
                            border-color: Theme.border_color;
                            border-width: 1px;
                            border-radius: 4px;
                            z: 999;
                            x: (parent.width - self.width) / 2;
                            y: -28px;
                            width: tt_text.width + 12px;
                            height: tt_text.height + 6px;
                            tt_text := Text {
                                text: move_path;
                                color: Theme.text_primary;
                                font-size: 11px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle {
                            width: 100%;
                            height: 100%;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Theme.input_border;
                            background: Theme.input_bg;
                            path_text := Text {
                                x: 15px;
                                width: parent.width - 30px;
                                text <=> move_path;
                                color: Theme.text_primary;
                                font-family: Theme.default_font;
                                font-size: 13px * LayoutConstants.font-scale;
                                vertical-alignment: center;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                                overflow: elide;
                            }
                        }
                        browse_touch := TouchArea {
                            width: 100%;
                            height: 100%;
                            mouse-cursor: pointer;
                            clicked => { root.browse(); }
                        }
                    }
                    CustomButton {
                        text: AppI18n.t("settings.select_folder", [AppI18n.version]);
                        height: 32px;
                        enabled: root.enabled;
                        clicked => {
                            root.browse();
                        }
                    }

                    if (AppI18n.is-rtl): Rectangle {
                        height: 32px;
                        horizontal-stretch: 1;
                        Rectangle {
                            visible: browse_touch2.has-hover && path_text2.preferred-width > path_text2.width;
                            opacity: browse_touch2.has-hover && path_text2.preferred-width > path_text2.width ? 1 : 0;
                            background: Theme.dark_mode ? #2D2D30 : #FFFFFF;
                            border-color: Theme.border_color;
                            border-width: 1px;
                            border-radius: 4px;
                            z: 999;
                            x: (parent.width - self.width) / 2;
                            y: -28px;
                            width: tt_text2.width + 12px;
                            height: tt_text2.height + 6px;
                            tt_text2 := Text {
                                text: move_path;
                                color: Theme.text_primary;
                                font-size: 11px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle {
                            width: 100%;
                            height: 100%;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Theme.input_border;
                            background: Theme.input_bg;
                            path_text2 := Text {
                                x: 15px;
                                width: parent.width - 30px;
                                text <=> move_path;
                                color: Theme.text_primary;
                                font-family: Theme.default_font;
                                font-size: 13px * LayoutConstants.font-scale;
                                vertical-alignment: center;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                                overflow: elide;
                            }
                        }
                        browse_touch2 := TouchArea {
                            width: 100%;
                            height: 100%;
                            mouse-cursor: pointer;
                            clicked => { root.browse(); }
                        }
                    }
                }
            }

            if (error_msg != ""): Text {
                text: error_msg;
                color: #ff3333;
                font-size: 12px * LayoutConstants.font-scale;
                font-family: Theme.default_font;
                wrap: word-wrap;
                horizontal-alignment: AppI18n.is-rtl ? right : left;
            }
            Rectangle {
                vertical-stretch: 1;
            } // Spacer

            HorizontalLayout {
                alignment: AppI18n.is-rtl ? start : end;
                spacing: 12px;
                if (AppI18n.is-rtl): CustomButton {
                    text: AppI18n.t("dialog.move_confirm", [AppI18n.version]);
                    height: 32px;
                    primary: true;
                    enabled: root.enabled;
                    clicked => {
                        root.confirm(move_path);
                    }
                }
                CustomButton {
                    text: AppI18n.t("dialog.cancel", [AppI18n.version]);
                    height: 32px;
                    clicked => {
                        root.cancel();
                    }
                }

                if (!AppI18n.is-rtl): CustomButton {
                    text: AppI18n.t("dialog.move_confirm", [AppI18n.version]);
                    height: 32px;
                    primary: true;
                    enabled: root.enabled;
                    clicked => {
                        root.confirm(move_path);
                    }
                }
            }
        }
    }
}
