import {
    Theme,
    Information,
    AppI18n,
    LayoutConstants,
} from "../../theme.slint";
import { ActionIcon } from "../common.slint";
import { CustomComboBox } from "../form_widgets.slint";

component InfoRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <color> value_color: Theme.text_primary;
    in property <bool> clickable: false;
    in property <bool> is_pill: false;
    in property <bool> show_copy_button: false;
    in property <string> copy_button_tooltip: AppI18n.t("dialog.copy_path", [AppI18n.version]);
    callback clicked;
    callback copy_clicked;
    height: 24px;
    Text {
        x: AppI18n.is-rtl ? parent.width - self.width : 0;
        text: root.label + ":" + (AppI18n.is-rtl ? "\u{200F}" : "");
        width: 110px;
        color: Theme.text_secondary;
        font-size: 13px * LayoutConstants.font-scale;
        font-family: Theme.default_font;
        vertical-alignment: center;
        horizontal-alignment: AppI18n.is-rtl ? right : left;
    }

    if (!is_pill): Rectangle {
        x: AppI18n.is-rtl ? 0 : 122px;
        width: parent.width - (AppI18n.is-rtl ? 110px : 122px);
        height: parent.height;

        // Value text with click area
        touch_area := TouchArea {
            x: AppI18n.is-rtl && show_copy_button ? 32px : 0;
            width: parent.width - (show_copy_button ? 32px : 0);
            height: parent.height;
            mouse-cursor: root.clickable ? pointer : default;
            clicked => {
                if (root.clickable) {
                    root.clicked();
                }
            }
            Rectangle {
                background: (root.clickable && touch_area.has-hover) ? (Theme.dark_mode ? #2D2D30 : #F0F0F0) : transparent;
                border-radius: 4px;
                width: parent.width;
                height: parent.height;
                Rectangle {
                    width: parent.width;
                    height: parent.height;
                    clip: true;
                    Text {
                        text: root.value;
                        color: (root.clickable && touch_area.has-hover) ? Theme.accent : root.value_color;
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        font-weight: 500;
                        vertical-alignment: center;
                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                        overflow: elide;
                        width: parent.width;
                    }
                }
            }
        }

        // Copy button
        if (show_copy_button): ActionIcon {
            x: AppI18n.is-rtl ? 0 : parent.width - 32px;
            y: (parent.height - 32px) / 2;
            height: 32px;
            icon: "\u{E8C8}";
            is_font_icon: true;
            tooltip: root.copy_button_tooltip;
            clicked => {
                root.copy_clicked();
            }
        }
    }
    if (is_pill): Rectangle {
        x: AppI18n.is-rtl ? parent.width - 110px - pill_text.width - 16px : 122px;
        width: pill_text.width + 16px;
        height: 20px;
        y: (parent.height - self.height) / 2;
        background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
        border-radius: 4px;
        pill_text := Text {
            text: root.value;
            color: Theme.accent;
            font-family: Theme.default_font;
            font-size: 12px * LayoutConstants.font-scale;
            font-weight: 500;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}

export component InformationDialog inherits Rectangle {
    in property <Information> info;
    in property <string> distro_name;
    in-out property <string> package_mirror: "";
    in property <string> distro_category: "";
    in property <bool> show-mirror-section: false;
    callback close;
    callback open_path(string);
    callback copy_to_clipboard(string);
    callback show_copy_success();
    callback copy_ip_clicked;
    callback resize_vhdx_clicked;
    callback compact_vhdx_clicked;
    callback set_sparse_clicked;
    callback unset_sparse_clicked;
    callback save_mirror(string);
    callback configure_mirror();
    
    pure function get-mirror-index(mirror: string) -> int {
        if (mirror == "tsinghua") { return 1; }
        if (mirror == "ustc") { return 2; }
        if (mirror == "aliyun") { return 3; }
        if (mirror == "tencent") { return 4; }
        if (mirror == "huawei") { return 5; }
        return 0;
    }
    pure function index-to-mirror(idx: int) -> string {
        if (idx == 1) { return "tsinghua"; }
        if (idx == 2) { return "ustc"; }
        if (idx == 3) { return "aliyun"; }
        if (idx == 4) { return "tencent"; }
        if (idx == 5) { return "huawei"; }
        return "";
    }
    pure function get-mirror-display-name(mirror: string) -> string {
        if (mirror == "tsinghua") { return AppI18n.t("dialog.mirror_tsinghua", [AppI18n.version]); }
        if (mirror == "ustc") { return AppI18n.t("dialog.mirror_ustc", [AppI18n.version]); }
        if (mirror == "aliyun") { return AppI18n.t("dialog.mirror_aliyun", [AppI18n.version]); }
        if (mirror == "tencent") { return AppI18n.t("dialog.mirror_tencent", [AppI18n.version]); }
        if (mirror == "huawei") { return AppI18n.t("dialog.mirror_huawei", [AppI18n.version]); }
        return AppI18n.t("dialog.mirror_none", [AppI18n.version]);
    }
    pure function get-mirror-index-limited(mirror: string) -> int {
        if (mirror == "aliyun") { return 1; }
        if (mirror == "tencent") { return 2; }
        if (mirror == "huawei") { return 3; }
        return 0;
    }
    pure function index-to-mirror-limited(idx: int) -> string {
        if (idx == 1) { return "aliyun"; }
        if (idx == 2) { return "tencent"; }
        if (idx == 3) { return "huawei"; }
        return "";
    }
    pure function get-mirror-index-rocky(mirror: string) -> int {
        if (mirror == "ustc") { return 1; }
        if (mirror == "aliyun") { return 2; }
        if (mirror == "tencent") { return 3; }
        if (mirror == "huawei") { return 4; }
        return 0;
    }
    pure function index-to-mirror-rocky(idx: int) -> string {
        if (idx == 1) { return "ustc"; }
        if (idx == 2) { return "aliyun"; }
        if (idx == 3) { return "tencent"; }
        if (idx == 4) { return "huawei"; }
        return "";
    }
    pure function get-mirror-index-centos(mirror: string) -> int {
        if (mirror == "tsinghua") { return 1; }
        if (mirror == "aliyun") { return 2; }
        if (mirror == "tencent") { return 3; }
        if (mirror == "huawei") { return 4; }
        return 0;
    }
    pure function index-to-mirror-centos(idx: int) -> string {
        if (idx == 1) { return "tsinghua"; }
        if (idx == 2) { return "aliyun"; }
        if (idx == 3) { return "tencent"; }
        if (idx == 4) { return "huawei"; }
        return "";
    }

    // Background mask
    background: #00000080;

    // Close on mask click
    TouchArea {
        clicked => {
            root.close();
        }
    }

    // Dialog Box
    Rectangle {
        width: 500px;
        height: min(main_layout.preferred-height, 500px);
        background: Theme.card_bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.border_color;
        clip: true;
        TouchArea { /* prevent click through */ }

        main_layout := VerticalLayout {
            padding: 24px;
            spacing: 12px;

            // Header
            Rectangle {
                height: 24px;
                Text {
                    x: AppI18n.is-rtl ? 32px : 0;
                    width: parent.width - 32px;
                    text: AppI18n.t("dialog.info_title", [root.info.distro_name, AppI18n.version]);
                    font-size: 18px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    font-weight: 500;
                    color: Theme.text_primary;
                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                    vertical-alignment: center;
                }

                TouchArea {
                    x: AppI18n.is-rtl ? 0 : parent.width - self.width;
                    width: 24px;
                    height: 24px;
                    clicked => {
                        root.close();
                    }
                    Rectangle {
                        background: parent.has-hover ? Theme.hover_bg : transparent;
                        border-radius: 4px;
                        Text {
                            text: "\u{E8BB}";
                            font-family: Theme.icon_font;
                            font-size: 14px;
                            color: Theme.text_primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: Theme.border_color;
            }

            // Content
            VerticalLayout {
                spacing: 8px;
                alignment: start;
                InfoRow {
                    label: AppI18n.t("dialog.wsl_version", [AppI18n.version]);
                    value: root.info.wsl_version;
                }

                InfoRow {
                    label: AppI18n.t("dialog.state", [AppI18n.version]);
                    value: (root.info.status == "Running") ? (AppI18n.t("distro.running", [AppI18n.version]) + (root.info.ip != "" ? " (IP: " + root.info.ip + " )" : "")) : AppI18n.t("distro.stopped", [AppI18n.version]);
                    value_color: root.info.status == "Running" ? #28a745 : Theme.text_primary;
                    show_copy_button: root.info.status == "Running" && root.info.ip != "";
                    copy_button_tooltip: AppI18n.t("dialog.copy_ip", [AppI18n.version]);
                    copy_clicked => {
                        root.copy_ip_clicked();
                    }
                }

                if (root.info.actual_used != ""): InfoRow {
                    label: AppI18n.t("dialog.internal_usage", [AppI18n.version]);
                    value: "(" + root.info.actual_used + " | " + root.info.actual_unused + ") / " + root.info.actual_total;
                    is_pill: true;
                }

                // --- VHDX Section ---
                if (root.info.wsl_version == "WSL2"): VerticalLayout {
                    spacing: 8px;
                    Rectangle {
                        height: 1px;
                        background: Theme.border_color.with-alpha(50%);
                    }

                    // === RTL: VHDX rows with HorizontalLayout for pill+icon ===
                    if (!AppI18n.is-rtl): Rectangle {
                        height: 24px;
                        Text {
                            x: 0;
                            text: AppI18n.t("dialog.vhdx_usage", [AppI18n.version]) + ":";
                            width: 110px;
                            color: Theme.text_secondary;
                            font-size: 13px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                        }

                        Rectangle {
                            x: 122px;
                            y: (parent.height - self.height) / 2;
                            width: usage_pill_text.width + 16px;
                            height: 20px;
                            background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
                            border-radius: 4px;
                            usage_pill_text := Text {
                                text: "(" + root.info.vhdx_size + " | " + root.info.drive_free + ") / " + root.info.drive_total;
                                color: Theme.accent;
                                font-family: Theme.default_font;
                                font-size: 12px * LayoutConstants.font-scale;
                                font-weight: 500;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }

                        if (root.info.vhdx_path != "" && root.info.status != "Running"): ActionIcon {
                            x: parent.width - 32px;
                            y: (parent.height - 28px) / 2;
                            width: 28px;
                            height: 28px;
                            icon: "\u{E927}";
                            is_font_icon: true;
                            tooltip: AppI18n.t("dialog.vhdx_compact_icon_tooltip", [AppI18n.version]);
                            tooltip_x_offset: -10px;
                            clicked => {
                                root.compact_vhdx_clicked();
                            }
                        }
                    }
                    if (AppI18n.is-rtl): Rectangle {
                        height: 24px;
                        HorizontalLayout {
                            spacing: 8px;
                            if (root.info.vhdx_path != "" && root.info.status != "Running"): ActionIcon {
                                width: 28px;
                                height: 28px;
                                icon: "\u{E927}";
                                is_font_icon: true;
                                tooltip: AppI18n.t("dialog.vhdx_compact_icon_tooltip", [AppI18n.version]);
                                tooltip_x_offset: 10px;
                                clicked => {
                                    root.compact_vhdx_clicked();
                                }
                            }
                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Rectangle {
                                height: 20px;
                                background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
                                border-radius: 4px;
                                up_rtl := Text {
                                    text: "(" + root.info.vhdx_size + " | " + root.info.drive_free + ") / " + root.info.drive_total;
                                    color: Theme.accent;
                                    font-family: Theme.default_font;
                                    font-size: 12px * LayoutConstants.font-scale;
                                    font-weight: 500;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                            }

                            Text {
                                text: AppI18n.t("dialog.vhdx_usage", [AppI18n.version]) + ":" + "\u{200F}";
                                width: 110px;
                                color: Theme.text_secondary;
                                font-size: 13px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                            }
                        }
                    }

                    if (!AppI18n.is-rtl): Rectangle {
                        height: 24px;
                        Text {
                            x: 0;
                            text: AppI18n.t("dialog.vhdx_virtual_size", [AppI18n.version]) + ":";
                            width: 110px;
                            color: Theme.text_secondary;
                            font-size: 13px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                        }

                        Rectangle {
                            x: 122px;
                            y: (parent.height - self.height) / 2;
                            width: virtual_pill_text.width + 16px;
                            height: 20px;
                            background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
                            border-radius: 4px;
                            virtual_pill_text := Text {
                                text: root.info.vhdx_virtual_size;
                                color: Theme.accent;
                                font-family: Theme.default_font;
                                font-size: 12px * LayoutConstants.font-scale;
                                font-weight: 500;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }

                        if (root.info.vhdx_path != "" && root.info.status != "Running"): ActionIcon {
                            x: parent.width - 32px;
                            y: (parent.height - 28px) / 2;
                            width: 28px;
                            height: 28px;
                            icon: "\u{E932}";
                            is_font_icon: true;
                            tooltip: AppI18n.t("dialog.vhdx_resize", [AppI18n.version]);
                            clicked => {
                                root.resize_vhdx_clicked();
                            }
                        }
                    }
                    if (AppI18n.is-rtl): Rectangle {
                        height: 24px;
                        HorizontalLayout {
                            spacing: 8px;
                            if (root.info.vhdx_path != "" && root.info.status != "Running"): ActionIcon {
                                width: 28px;
                                height: 28px;
                                icon: "\u{E932}";
                                is_font_icon: true;
                                tooltip: AppI18n.t("dialog.vhdx_resize", [AppI18n.version]);
                                clicked => {
                                    root.resize_vhdx_clicked();
                                }
                            }
                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Rectangle {
                                height: 20px;
                                background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
                                border-radius: 4px;
                                vp_rtl := Text {
                                    text: root.info.vhdx_virtual_size;
                                    color: Theme.accent;
                                    font-family: Theme.default_font;
                                    font-size: 12px * LayoutConstants.font-scale;
                                    font-weight: 500;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                            }

                            Text {
                                text: AppI18n.t("dialog.vhdx_virtual_size", [AppI18n.version]) + ":" + "\u{200F}";
                                width: 110px;
                                color: Theme.text_secondary;
                                font-size: 13px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                            }
                        }
                    }

                    InfoRow {
                        label: AppI18n.t("dialog.vhdx_type", [AppI18n.version]);
                        value: root.info.vhdx_type;
                        is_pill: true;
                    }

                    if (!AppI18n.is-rtl): Rectangle {
                        height: 24px;
                        Text {
                            x: 0;
                            text: AppI18n.t("dialog.vhdx_sparse", [AppI18n.version]) + ":";
                            width: 110px;
                            color: Theme.text_secondary;
                            font-size: 13px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                        }

                        Rectangle {
                            x: 122px;
                            y: (parent.height - self.height) / 2;
                            width: sparse_pill_text.width + 16px;
                            height: 20px;
                            background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
                            border-radius: 4px;
                            sparse_pill_text := Text {
                                text: root.info.vhdx_is_sparse ? AppI18n.t("dialog.vhdx_sparse_yes", [AppI18n.version]) : AppI18n.t("dialog.vhdx_sparse_no", [AppI18n.version]);
                                color: Theme.accent;
                                font-family: Theme.default_font;
                                font-size: 12px * LayoutConstants.font-scale;
                                font-weight: 500;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }

                        if (root.info.vhdx_path != "" && root.info.status != "Running" && !root.info.vhdx_is_sparse): ActionIcon {
                            x: parent.width - 32px;
                            y: (parent.height - 28px) / 2;
                            width: 28px;
                            height: 28px;
                            icon: "\u{E734}";
                            is_font_icon: true;
                            tooltip: AppI18n.t("dialog.vhdx_set_sparse", [AppI18n.version]);
                            tooltip_x_offset: -10px;
                            clicked => {
                                root.set_sparse_clicked();
                            }
                        }
                        if (root.info.vhdx_path != "" && root.info.status != "Running" && root.info.vhdx_is_sparse): ActionIcon {
                            x: parent.width - 32px;
                            y: (parent.height - 28px) / 2;
                            width: 28px;
                            height: 28px;
                            icon: "\u{E74D}";
                            is_font_icon: true;
                            tooltip: AppI18n.t("dialog.vhdx_unset_sparse", [AppI18n.version]);
                            tooltip_x_offset: -10px;
                            clicked => {
                                root.unset_sparse_clicked();
                            }
                        }
                    }
                    if (AppI18n.is-rtl): Rectangle {
                        height: 24px;
                        HorizontalLayout {
                            spacing: 8px;
                            if (root.info.vhdx_path != "" && root.info.status != "Running" && !root.info.vhdx_is_sparse): ActionIcon {
                                width: 28px;
                                height: 28px;
                                icon: "\u{E734}";
                                is_font_icon: true;
                                tooltip: AppI18n.t("dialog.vhdx_set_sparse", [AppI18n.version]);
                                tooltip_x_offset: 10px;
                                clicked => {
                                    root.set_sparse_clicked();
                                }
                            }
                            if (root.info.vhdx_path != "" && root.info.status != "Running" && root.info.vhdx_is_sparse): ActionIcon {
                                width: 28px;
                                height: 28px;
                                icon: "\u{E74D}";
                                is_font_icon: true;
                                tooltip: AppI18n.t("dialog.vhdx_unset_sparse", [AppI18n.version]);
                                tooltip_x_offset: 10px;
                                clicked => {
                                    root.unset_sparse_clicked();
                                }
                            }
                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Rectangle {
                                height: 20px;
                                background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
                                border-radius: 4px;
                                sp_rtl := Text {
                                    text: root.info.vhdx_is_sparse ? AppI18n.t("dialog.vhdx_sparse_yes", [AppI18n.version]) : AppI18n.t("dialog.vhdx_sparse_no", [AppI18n.version]);
                                    color: Theme.accent;
                                    font-family: Theme.default_font;
                                    font-size: 12px * LayoutConstants.font-scale;
                                    font-weight: 500;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                            }

                            Text {
                                text: AppI18n.t("dialog.vhdx_sparse", [AppI18n.version]) + ":" + "\u{200F}";
                                width: 110px;
                                color: Theme.text_secondary;
                                font-size: 13px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                            }
                        }
                    }

                    InfoRow {
                        label: AppI18n.t("dialog.vhdx_location", [AppI18n.version]);
                        value: root.info.vhdx_path;
                        clickable: true;
                        show_copy_button: root.info.vhdx_path != "";
                        clicked => {
                            root.open_path(root.info.install_location);
                        }
                        copy_clicked => {
                            root.copy_to_clipboard(root.info.vhdx_path);
                            root.show_copy_success();
                        }
                    }
                }

                // Mirror Source Section (button to load + configure)
                if (AppI18n.locale-code == "zh-CN"): VerticalLayout {
                    spacing: 8px;
                    Rectangle {
                        height: 1px;
                        background: Theme.border_color.with-alpha(50%);
                    }

                    // Collapsed: show current value + gear icon button
                    if (!root.show-mirror-section): Rectangle {
                        height: 24px;
                        Text {
                            x: 0;
                            width: 110px;
                            height: 100%;
                            text: AppI18n.t("dialog.mirror_source", [AppI18n.version]) + ":";
                            color: Theme.text_secondary;
                            font-size: 13px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                        }
                        Text {
                            x: 122px;
                            height: 100%;
                            text: {
                                if (root.package_mirror != "") { return root.get-mirror-display-name(root.package_mirror); }
                                return AppI18n.t("dialog.mirror_none", [AppI18n.version]);
                            };
                            color: Theme.text_primary;
                            font-size: 13px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            vertical-alignment: center;
                        }
                        ActionIcon {
                            x: parent.width - 32px;
                            y: (parent.height - 28px) / 2;
                            width: 28px;
                            height: 28px;
                            icon: "\u{E713}";
                            is_font_icon: true;
                            tooltip: AppI18n.t("dialog.mirror_configure", [AppI18n.version]);
                            clicked => { root.configure_mirror(); }
                        }
                    }

                    // Expanded: dropdowns
                    if (root.show-mirror-section && (root.distro_category == "ubuntu" || root.distro_category == "debian" || root.distro_category == "kali" || root.distro_category == "centos" || root.distro_category == "fedora" || root.distro_category == "archlinux" || root.distro_category == "almalinux" || root.distro_category == "rocky" || root.distro_category == "opensuse" || root.distro_category == "alpine")): VerticalLayout {
                        spacing: 8px;

                        // APT (Ubuntu/Debian/Kali)
                        if (root.distro_category == "ubuntu" || root.distro_category == "debian" || root.distro_category == "kali"): VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: AppI18n.t("dialog.mirror_apt", [AppI18n.version]);
                                font-size: 12px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_secondary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                CustomComboBox {
                                    horizontal-stretch: 1;
                                    model: [
                                        AppI18n.t("dialog.mirror_none", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tsinghua", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_ustc", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_aliyun", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tencent", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_huawei", [AppI18n.version])
                                    ];
                                    current-index: root.get-mirror-index(root.package_mirror);
                                    selected(idx) => {
                                        root.package_mirror = root.index-to-mirror(idx);
                                        root.save_mirror(root.package_mirror);
                                    }
                                }
                            }
                        }

                        // APK (Alpine Linux)
                        if (root.distro_category == "alpine"): VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: AppI18n.t("dialog.mirror_apk", [AppI18n.version]);
                                font-size: 12px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_secondary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                CustomComboBox {
                                    horizontal-stretch: 1;
                                    model: [
                                        AppI18n.t("dialog.mirror_none", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tsinghua", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_ustc", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_aliyun", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tencent", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_huawei", [AppI18n.version])
                                    ];
                                    current-index: root.get-mirror-index(root.package_mirror);
                                    selected(idx) => {
                                        root.package_mirror = root.index-to-mirror(idx);
                                        root.save_mirror(root.package_mirror);
                                    }
                                }
                            }
                        }

                        // DNF (CentOS/Fedora/AlmaLinux/Rocky/openSUSE)
                        if (root.distro_category == "centos" || root.distro_category == "fedora" || root.distro_category == "almalinux" || root.distro_category == "rocky" || root.distro_category == "opensuse"): VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: AppI18n.t("dialog.mirror_dnf", [AppI18n.version]);
                                font-size: 12px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_secondary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                if (root.distro_category == "almalinux"): CustomComboBox {
                                    horizontal-stretch: 1;
                                    model: [
                                        AppI18n.t("dialog.mirror_none", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_aliyun", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tencent", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_huawei", [AppI18n.version])
                                    ];
                                    current-index: root.get-mirror-index-limited(root.package_mirror);
                                    selected(idx) => {
                                        root.package_mirror = root.index-to-mirror-limited(idx);
                                        root.save_mirror(root.package_mirror);
                                    }
                                }
                                if (root.distro_category == "rocky"): CustomComboBox {
                                    horizontal-stretch: 1;
                                    model: [
                                        AppI18n.t("dialog.mirror_none", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_ustc", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_aliyun", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tencent", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_huawei", [AppI18n.version])
                                    ];
                                    current-index: root.get-mirror-index-rocky(root.package_mirror);
                                    selected(idx) => {
                                        root.package_mirror = root.index-to-mirror-rocky(idx);
                                        root.save_mirror(root.package_mirror);
                                    }
                                }
                                if (root.distro_category == "centos"): CustomComboBox {
                                    horizontal-stretch: 1;
                                    model: [
                                        AppI18n.t("dialog.mirror_none", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tsinghua", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_aliyun", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tencent", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_huawei", [AppI18n.version])
                                    ];
                                    current-index: root.get-mirror-index-centos(root.package_mirror);
                                    selected(idx) => {
                                        root.package_mirror = root.index-to-mirror-centos(idx);
                                        root.save_mirror(root.package_mirror);
                                    }
                                }
                                if (root.distro_category == "fedora" || root.distro_category == "opensuse"): CustomComboBox {
                                    horizontal-stretch: 1;
                                    model: [
                                        AppI18n.t("dialog.mirror_none", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tsinghua", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_ustc", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_aliyun", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tencent", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_huawei", [AppI18n.version])
                                    ];
                                    current-index: root.get-mirror-index(root.package_mirror);
                                    selected(idx) => {
                                        root.package_mirror = root.index-to-mirror(idx);
                                        root.save_mirror(root.package_mirror);
                                    }
                                }
                            }
                        }

                        // Pacman (Arch Linux)
                        if (root.distro_category == "archlinux"): VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: AppI18n.t("dialog.mirror_pacman", [AppI18n.version]);
                                font-size: 12px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_secondary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                CustomComboBox {
                                    horizontal-stretch: 1;
                                    model: [
                                        AppI18n.t("dialog.mirror_none", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tsinghua", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_ustc", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_aliyun", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_tencent", [AppI18n.version]),
                                        AppI18n.t("dialog.mirror_huawei", [AppI18n.version])
                                    ];
                                    current-index: root.get-mirror-index(root.package_mirror);
                                    selected(idx) => {
                                        root.package_mirror = root.index-to-mirror(idx);
                                        root.save_mirror(root.package_mirror);
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Footer
            HorizontalLayout {
                alignment: AppI18n.is-rtl ? start : end;
                spacing: 8px;
                Rectangle {
                    width: 90px;
                    height: 32px;
                    background: Theme.accent;
                    border-radius: 6px;
                    Text {
                        text: AppI18n.t("dialog.confirm", [AppI18n.version]);
                        color: white;
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.close();
                        }
                    }
                }
            }
        }
    }
}
