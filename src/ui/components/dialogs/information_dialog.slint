import {
    Theme,
    Information,
    AppI18n,
    LayoutConstants,
} from "../../theme.slint";
import { ActionIcon } from "../common.slint";

component InfoRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <color> value_color: Theme.text_primary;
    in property <bool> clickable: false;
    in property <bool> is_pill: false;
    in property <bool> show_copy_button: false;
    in property <string> copy_button_tooltip: AppI18n.t("dialog.copy_path", [AppI18n.version]);
    callback clicked;
    callback copy_clicked;
    height: 24px;
    Text {
        x: AppI18n.is-rtl ? parent.width - self.width : 0;
        text: root.label + ":" + (AppI18n.is-rtl ? "\u{200F}" : "");
        width: 110px;
        color: Theme.text_secondary;
        font-size: 13px * LayoutConstants.font-scale;
        font-family: Theme.default_font;
        vertical-alignment: center;
        horizontal-alignment: AppI18n.is-rtl ? right : left;
    }

    if (!is_pill): Rectangle {
        x: AppI18n.is-rtl ? 0 : 122px;
        width: parent.width - 122px;
        height: parent.height;

        // Value text with click area
        touch_area := TouchArea {
            x: 0;
            width: parent.width - (show_copy_button ? 32px : 0);
            height: parent.height;
            mouse-cursor: root.clickable ? pointer : default;
            clicked => {
                if (root.clickable) {
                    root.clicked();
                }
            }
            Rectangle {
                background: (root.clickable && touch_area.has-hover) ? (Theme.dark_mode ? #2D2D30 : #F0F0F0) : transparent;
                border-radius: 4px;
                width: parent.width;
                height: parent.height;
                Rectangle {
                    width: parent.width;
                    height: parent.height;
                    clip: true;
                    Text {
                        text: root.value;
                        color: (root.clickable && touch_area.has-hover) ? Theme.accent : root.value_color;
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        font-weight: 500;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        overflow: elide;
                        width: parent.width;
                    }
                }
            }
        }

        // Copy button
        if (show_copy_button): ActionIcon {
            x: parent.width - 32px;
            y: (parent.height - 32px) / 2;
            height: 32px;
            icon: "\u{E8C8}";
            is_font_icon: true;
            tooltip: root.copy_button_tooltip;
            clicked => {
                root.copy_clicked();
            }
        }
    }
    if (is_pill): Rectangle {
        x: AppI18n.is-rtl ? 0 : 122px;
        width: pill_text.width + 16px;
        height: 20px;
        y: (parent.height - self.height) / 2;
        background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
        border-radius: 4px;
        pill_text := Text {
            text: root.value;
            color: Theme.accent;
            font-family: Theme.default_font;
            font-size: 12px * LayoutConstants.font-scale;
            font-weight: 500;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}

export component InformationDialog inherits Rectangle {
    in property <Information> info;
    callback close;
    callback open_path(string);
    callback copy_to_clipboard(string);
    callback show_copy_success();
    callback copy_ip_clicked;
    callback resize_vhdx_clicked;
    callback compact_vhdx_clicked;
    callback set_sparse_clicked;
    callback unset_sparse_clicked;

    // Background mask
    background: #00000080;

    // Close on mask click
    TouchArea {
        clicked => {
            root.close();
        }
    }

    // Dialog Box
    Rectangle {
        width: 500px;
        height: min(main_layout.preferred-height, 500px);
        background: Theme.card_bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.border_color;
        clip: true;
        TouchArea { /* prevent click through */ }

        main_layout := VerticalLayout {
            padding: 24px;
            spacing: 12px;

            // Header
            Rectangle {
                height: 24px;
                Text {
                    x: AppI18n.is-rtl ? 32px : 0;
                    width: parent.width - 32px;
                    text: AppI18n.t("dialog.info_title", [root.info.distro_name, AppI18n.version]);
                    font-size: 18px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    font-weight: 500;
                    color: Theme.text_primary;
                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                    vertical-alignment: center;
                }

                TouchArea {
                    x: AppI18n.is-rtl ? 0 : parent.width - self.width;
                    width: 24px;
                    height: 24px;
                    clicked => {
                        root.close();
                    }
                    Rectangle {
                        background: parent.has-hover ? Theme.hover_bg : transparent;
                        border-radius: 4px;
                        Text {
                            text: "\u{E8BB}";
                            font-family: Theme.icon_font;
                            font-size: 14px;
                            color: Theme.text_primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: Theme.border_color;
            }

            // Content
            VerticalLayout {
                spacing: 8px;
                alignment: start;
                InfoRow {
                    label: AppI18n.t("dialog.wsl_version", [AppI18n.version]);
                    value: root.info.wsl_version;
                }

                InfoRow {
                    label: AppI18n.t("dialog.state", [AppI18n.version]);
                    value: (root.info.status == "Running")
                        ? (AppI18n.t("distro.running", [AppI18n.version]) + (root.info.ip != "" ? " (IP: " + root.info.ip + " )" : ""))
                        : AppI18n.t("distro.stopped", [AppI18n.version]);
                    value_color: root.info.status == "Running" ? #28a745 : Theme.text_primary;
                    show_copy_button: root.info.status == "Running" && root.info.ip != "";
                    copy_button_tooltip: AppI18n.t("dialog.copy_ip", [AppI18n.version]);
                    copy_clicked => {
                        root.copy_ip_clicked();
                    }
                }

                if (root.info.actual_used != ""): InfoRow {
                    label: AppI18n.t("dialog.internal_usage", [AppI18n.version]);
                    value: "(" + root.info.actual_used + " | " + root.info.actual_unused + ")" + " / " + root.info.actual_total;
                    is_pill: true;
                }

                // --- VHDX Section ---
                if (root.info.wsl_version == "WSL2"): VerticalLayout {
                    spacing: 8px;
                    Rectangle {
                        height: 1px;
                        background: Theme.border_color.with-alpha(50%);
                    }

                    Rectangle {
                        height: 24px;
                        Text {
                            x: AppI18n.is-rtl ? parent.width - self.width : 0;
                            text: AppI18n.t("dialog.vhdx_usage", [AppI18n.version]) + ":" + (AppI18n.is-rtl ? "\u{200F}" : "");
                            width: 110px;
                            color: Theme.text_secondary;
                            font-size: 13px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            vertical-alignment: center;
                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                        }
                        Rectangle {
                            x: AppI18n.is-rtl ? 0 : 122px;
                            y: (parent.height - self.height) / 2;
                            width: usage_pill_text.width + 16px;
                            height: 20px;
                            background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
                            border-radius: 4px;
                            usage_pill_text := Text {
                                text: "(" + root.info.vhdx_size + " | " + root.info.drive_free + ")" + " / " + root.info.drive_total;
                                color: Theme.accent;
                                font-family: Theme.default_font;
                                font-size: 12px * LayoutConstants.font-scale;
                                font-weight: 500;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }
                        if (root.info.vhdx_path != "" && root.info.status != "Running"): ActionIcon {
                            x: parent.width - 32px;
                            y: (parent.height - 28px) / 2;
                            width: 28px;
                            height: 28px;
                            icon: "\u{E927}";
                            is_font_icon: true;
                            tooltip: AppI18n.t("dialog.vhdx_compact_icon_tooltip", [AppI18n.version]);
                            tooltip_x_offset: -10px;
                            clicked => {
                                root.compact_vhdx_clicked();
                            }
                        }
                    }

                    Rectangle {
                        height: 24px;
                        Text {
                            x: AppI18n.is-rtl ? parent.width - self.width : 0;
                            text: AppI18n.t("dialog.vhdx_virtual_size", [AppI18n.version]) + ":" + (AppI18n.is-rtl ? "\u{200F}" : "");
                            width: 110px;
                            color: Theme.text_secondary;
                            font-size: 13px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            vertical-alignment: center;
                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                        }
                        Rectangle {
                            x: AppI18n.is-rtl ? 0 : 122px;
                            y: (parent.height - self.height) / 2;
                            width: virtual_pill_text.width + 16px;
                            height: 20px;
                            background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
                            border-radius: 4px;
                            virtual_pill_text := Text {
                                text: root.info.vhdx_virtual_size;
                                color: Theme.accent;
                                font-family: Theme.default_font;
                                font-size: 12px * LayoutConstants.font-scale;
                                font-weight: 500;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }
                        if (root.info.vhdx_path != "" && root.info.status != "Running"): ActionIcon {
                            x: parent.width - 28px;
                            y: (parent.height - 20px) / 2;
                            width: 20px;
                            height: 20px;
                            icon: "\u{E932}";
                            is_font_icon: true;
                            tooltip: AppI18n.t("dialog.vhdx_resize", [AppI18n.version]);
                            clicked => {
                                root.resize_vhdx_clicked();
                            }
                        }
                    }

                    InfoRow {
                        label: AppI18n.t("dialog.vhdx_type", [AppI18n.version]);
                        value: root.info.vhdx_type;
                        is_pill: true;
                    }

                    Rectangle {
                        height: 24px;
                        Text {
                            x: AppI18n.is-rtl ? parent.width - self.width : 0;
                            text: AppI18n.t("dialog.vhdx_sparse", [AppI18n.version]) + ":" + (AppI18n.is-rtl ? "\u{200F}" : "");
                            width: 110px;
                            color: Theme.text_secondary;
                            font-size: 13px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            vertical-alignment: center;
                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                        }
                        Rectangle {
                            x: AppI18n.is-rtl ? 0 : 122px;
                            y: (parent.height - self.height) / 2;
                            width: sparse_pill_text.width + 16px;
                            height: 20px;
                            background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
                            border-radius: 4px;
                            sparse_pill_text := Text {
                                text: root.info.vhdx_is_sparse ? AppI18n.t("dialog.vhdx_sparse_yes", [AppI18n.version]) : AppI18n.t("dialog.vhdx_sparse_no", [AppI18n.version]);
                                color: Theme.accent;
                                font-family: Theme.default_font;
                                font-size: 12px * LayoutConstants.font-scale;
                                font-weight: 500;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }
                        if (root.info.vhdx_path != "" && root.info.status != "Running" && !root.info.vhdx_is_sparse): ActionIcon {
                            x: parent.width - 28px;
                            y: (parent.height - 20px) / 2;
                            width: 20px;
                            height: 20px;
                            icon: "\u{E734}";
                            is_font_icon: true;
                            tooltip: AppI18n.t("dialog.vhdx_set_sparse", [AppI18n.version]);
                            tooltip_x_offset: -10px;
                            clicked => {
                                root.set_sparse_clicked();
                            }
                        }
                        if (root.info.vhdx_path != "" && root.info.status != "Running" && root.info.vhdx_is_sparse): ActionIcon {
                            x: parent.width - 28px;
                            y: (parent.height - 20px) / 2;
                            width: 20px;
                            height: 20px;
                            icon: "\u{E74D}";
                            is_font_icon: true;
                            tooltip: AppI18n.t("dialog.vhdx_unset_sparse", [AppI18n.version]);
                            tooltip_x_offset: -10px;
                            clicked => {
                                root.unset_sparse_clicked();
                            }
                        }
                    }

                    InfoRow {
                        label: AppI18n.t("dialog.vhdx_location", [AppI18n.version]);
                        value: root.info.vhdx_path;
                        clickable: true;
                        show_copy_button: root.info.vhdx_path != "";
                        clicked => {
                            root.open_path(root.info.install_location);
                        }
                        copy_clicked => {
                            root.copy_to_clipboard(root.info.vhdx_path);
                            root.show_copy_success();
                        }
                    }
                }
            }

            // Footer
            HorizontalLayout {
                alignment: AppI18n.is-rtl ? start : end;
                spacing: 8px;
                Rectangle {
                    width: 90px;
                    height: 32px;
                    background: Theme.accent;
                    border-radius: 6px;
                    Text {
                        text: AppI18n.t("dialog.confirm", [AppI18n.version]);
                        color: white;
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.close();
                        }
                    }
                }
            }
        }
    }
}
