import {
    Theme,
    AppI18n,
    WslManageStrings,
    LayoutConstants,
} from "../theme.slint";
import {
    CustomButton,
    CustomCheckBox,
    CustomComboBox,
    CustomLineEdit,
    ToggleButton,
} from "../components/form_widgets.slint";
import { CustomScrollbar } from "../components/scrollbar.slint";
import { EmptyState } from "../components/common.slint";

// Status badge component
component StatusBadge inherits Rectangle {
    in property <string> text: "";
    in property <color> bg-color: Theme.status_success;
    height: 24px;
    border-radius: 12px;
    background: root.bg-color.with-alpha(20%);
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        height: 100%;
        alignment: center;
        // Dot indicator
        Text {
            text: "\u{25CF}";
            font-size: 10px;
            color: root.bg-color;
            vertical-alignment: center;
        }

        Text {
            text: root.text;
            font-size: 12px * LayoutConstants.font-scale;
            font-family: Theme.default_font;
            color: root.bg-color;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}

// Code block component for displaying command output
component CodeBlock inherits Rectangle {
    in property <string> text: "";
    min-width: 0;
    background: Theme.code_bg;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.border_color;
    clip: true;

    VerticalLayout {
        min-width: 0;
        padding: 12px;
        padding-left: AppI18n.is-rtl ? 12px : 16px;
        padding-right: AppI18n.is-rtl ? 16px : 12px;
        Text {
            min-width: 0;
            text: root.text;
            font-size: 12.5px * LayoutConstants.font-scale;
            font-family: Theme.mono_font;
            color: Theme.code_fg;
            horizontal-alignment: AppI18n.is-rtl ? right : left;
        }
    }
}

// Action pill button (icon + text in one row, color-tinted)
component ActionPill inherits Rectangle {
    in property <string> icon: "";
    in property <string> text: "";
    in property <color> accent-color: Theme.accent;
    callback clicked;
    height: 32px;
    border-radius: 4px;
    background: touch.has-hover ? accent-color.with-alpha(15%) : accent-color.with-alpha(8%);
    border-width: 1px;
    border-color: accent-color.with-alpha(25%);
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 6px;
        alignment: center;
        Text {
            text: root.icon;
            font-family: Theme.icon_font;
            font-size: 14px;
            color: root.accent-color;
            vertical-alignment: center;
            horizontal-alignment: center;
        }

        Text {
            text: root.text;
            font-size: 13px * LayoutConstants.font-scale;
            font-family: Theme.default_font;
            font-weight: 500;
            color: root.accent-color;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

// One-row action layout: icon + title/description on left, button on right
component ActionRow inherits Rectangle {
    in property <string> icon: "";
    in property <string> title: "";
    in property <string> description: "";
    in property <string> button-text: "";
    in property <string> button-style: "default";   // "default" | "primary" | "danger"
    in property <bool> show-shield: false;
    in property <bool> enabled: true;
    callback clicked;
    height: 72px;
    if (!AppI18n.is-rtl): HorizontalLayout {
        padding-left: 0px;
        padding-right: 0px;
        spacing: 12px;

        // LTR: icon+text left, button right
        HorizontalLayout {
            spacing: 12px;
            horizontal-stretch: 1;
            alignment: start;

            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;

                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;

                    Rectangle {
                        width: 36px;
                        height: 36px;
                        border-radius: 6px;
                        background: Theme.surface_subtle;
                        Text {
                            text: root.icon;
                            font-family: Theme.icon_font;
                            font-size: 16px;
                            color: root.button-style == "danger" ? Theme.status_danger : (root.button-style == "primary" ? Theme.accent : Theme.text_secondary);
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        horizontal-stretch: 1;
                        Text {
                            text: root.title;
                            font-size: 14px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            font-weight: 500;
                            color: Theme.text_primary;
                            horizontal-alignment: left;
                            overflow: elide;
                        }

                        Text {
                            text: root.description;
                            font-size: 12px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            color: Theme.text_secondary;
                            wrap: word-wrap;
                            horizontal-alignment: left;
                        }
                    }
                }
            }
        }

        VerticalLayout {
            alignment: center;
            Rectangle {
                height: 32px;
                CustomButton {
                    text: root.button-text;
                    primary: root.button-style == "primary";
                    danger: root.button-style == "danger";
                    show_shield: root.show-shield;
                    enabled: root.enabled;
                    height: 32px;
                    clicked => {
                        root.clicked();
                    }
                }
            }
        }
    }
    if (AppI18n.is-rtl): HorizontalLayout {
        padding-left: 0px;
        padding-right: 0px;
        spacing: 12px;

        // RTL: button left, icon+text right
        VerticalLayout {
            alignment: center;
            Rectangle {
                height: 32px;
                CustomButton {
                    text: root.button-text;
                    primary: root.button-style == "primary";
                    danger: root.button-style == "danger";
                    show_shield: root.show-shield;
                    enabled: root.enabled;
                    height: 32px;
                    clicked => {
                        root.clicked();
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 12px;
            horizontal-stretch: 1;
            alignment: end;

            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;

                HorizontalLayout {
                    spacing: 12px;
                    alignment: end;

                    VerticalLayout {
                        spacing: 4px;
                        horizontal-stretch: 1;
                        Text {
                            text: root.title;
                            font-size: 14px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            font-weight: 500;
                            color: Theme.text_primary;
                            horizontal-alignment: right;
                            overflow: elide;
                        }

                        Text {
                            text: root.description;
                            font-size: 12px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            color: Theme.text_secondary;
                            wrap: word-wrap;
                            horizontal-alignment: right;
                        }
                    }

                    Rectangle {
                        width: 36px;
                        height: 36px;
                        border-radius: 6px;
                        background: Theme.surface_subtle;
                        Text {
                            text: root.icon;
                            font-family: Theme.icon_font;
                            font-size: 16px;
                            color: root.button-style == "danger" ? Theme.status_danger : (root.button-style == "primary" ? Theme.accent : Theme.text_secondary);
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

component Divider inherits Rectangle {
    height: 1px;
    background: Theme.border_color;
}

export component WslManageView inherits Rectangle {
    // Static labels (i18n)
    in property <WslManageStrings> strings;

    // Dynamic data from backend
    in property <bool> wsl_installed: false;
    in property <int> default_version: 2;
    in property <bool> has_running_instances: false;
    in property <bool> has_instances: false;
    in property <bool> is_updating: false;
    in property <string> version_text: "";
    in property <string> status_text: "";
    in property <string> default_distro_name;

    in-out property <bool> vhdx_sparse_mode: false;

    // Disk mount properties
    in-out property <string> disk_path: "";
    in-out property <bool> disk_is_vhd: false;
    in-out property <bool> disk_is_bare: false;
    in-out property <string> disk_mount_name: "";
    in-out property <string> disk_fs_type: "ext4";
    in-out property <string> disk_partition: "";
    in-out property <string> disk_options: "";
    in property <bool> mount_running: false;
    in property <string> mount_output: "";
    in property <bool> mount_is_error: false;
    in property <[string]> mounted_disks: [];
    in property <[string]> physical_disks: [];
    in property <[string]> physical_disks_paths: [];
    in property <[string]> physical_disks_names: [];

    // Callbacks
    callback install_wsl();
    callback start_wsl();
    callback update_wsl();
    callback shutdown_all();
    callback set_default_version(int);
    callback uninstall_wsl();
    callback open_wsl_settings();
    callback sparse_mode_toggled();
    callback mount_disk();
    callback unmount_disk(string);
    callback unmount_all_disks();
    callback refresh_mounted_disks();
    callback refresh_physical_disks();
    callback browse_vhd();

    VerticalLayout {
        spacing: 12px;
        padding-left: AppI18n.is-rtl ? 16px : 4px;
        padding-right: AppI18n.is-rtl ? 4px : 16px;
        padding-top: 8px;
        padding-bottom: 8px;

        Rectangle {
            clip: true;
            vertical-stretch: 1;

            flick := Flickable {
                viewport-height: content-layout.preferred-height;
                width: parent.width;
                height: 100%;

                content-layout := VerticalLayout {
                    width: parent.width;
                    spacing: 12px;

                    // === Status Header Card ===
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 52px;
                        background: Theme.card_bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border_color;
                        if (!AppI18n.is-rtl): HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 12px;
                            alignment: center;

                            // LTR: Left=title+badge, Right=action pill
                            HorizontalLayout {
                                spacing: 10px;
                                horizontal-stretch: 1;
                                Text {
                                    text: root.strings.status_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    vertical-alignment: center;
                                }

                                if (root.wsl_installed): VerticalLayout {
                                    alignment: center;
                                    StatusBadge {
                                        text: root.has_running_instances ? root.strings.status_running : root.strings.status_stopped;
                                        bg-color: root.has_running_instances ? Theme.status_success : Theme.status_warning;
                                    }
                                }
                                if (!root.wsl_installed): VerticalLayout {
                                    alignment: center;
                                    StatusBadge {
                                        text: root.strings.status_not_installed;
                                        bg-color: Theme.status_danger;
                                    }
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                if (!root.wsl_installed): ActionPill {
                                    icon: "\u{E945}";
                                    text: root.strings.install_btn;
                                    accent-color: Theme.accent;
                                    clicked => {
                                        root.install_wsl();
                                    }
                                }
                                if (root.wsl_installed && root.has_running_instances): ActionPill {
                                    icon: "\u{E769}";
                                    text: root.strings.shutdown_btn;
                                    accent-color: Theme.status_danger;
                                    clicked => {
                                        root.shutdown_all();
                                    }
                                }
                                if (root.wsl_installed && !root.has_running_instances && root.has_instances): ActionPill {
                                    icon: "\u{E768}";
                                    text: AppI18n.t("wsl_manage.start_btn", [AppI18n.version]);
                                    accent-color: Theme.status_success;
                                    clicked => {
                                        root.start_wsl();
                                    }
                                }
                            }
                        }
                        if (AppI18n.is-rtl): HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 12px;
                            alignment: center;

                            // RTL: Left=action pill, Right=title+badge
                            VerticalLayout {
                                alignment: center;
                                if (!root.wsl_installed): ActionPill {
                                    icon: "\u{E945}";
                                    text: root.strings.install_btn;
                                    accent-color: Theme.accent;
                                    clicked => {
                                        root.install_wsl();
                                    }
                                }
                                if (root.wsl_installed && root.has_running_instances): ActionPill {
                                    icon: "\u{E769}";
                                    text: root.strings.shutdown_btn;
                                    accent-color: Theme.status_danger;
                                    clicked => {
                                        root.shutdown_all();
                                    }
                                }
                                if (root.wsl_installed && !root.has_running_instances && root.has_instances): ActionPill {
                                    icon: "\u{E768}";
                                    text: AppI18n.t("wsl_manage.start_btn", [AppI18n.version]);
                                    accent-color: Theme.status_success;
                                    clicked => {
                                        root.start_wsl();
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                horizontal-stretch: 1;
                                Text {
                                    text: root.strings.status_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    vertical-alignment: center;
                                }

                                if (root.wsl_installed): VerticalLayout {
                                    alignment: center;
                                    StatusBadge {
                                        text: root.has_running_instances ? root.strings.status_running : root.strings.status_stopped;
                                        bg-color: root.has_running_instances ? Theme.status_success : Theme.status_warning;
                                    }
                                }
                                if (!root.wsl_installed): VerticalLayout {
                                    alignment: center;
                                    StatusBadge {
                                        text: root.strings.status_not_installed;
                                        bg-color: Theme.status_danger;
                                    }
                                }
                            }
                        }
                    }

                    // === Version & Status Info side by side ===
                    if (root.wsl_installed && (root.version_text != "" || root.status_text != "")): HorizontalLayout {
                        spacing: 12px;
                        // LTR: Version left, Status right
                        if (!AppI18n.is-rtl && root.version_text != ""): Rectangle {
                            horizontal-stretch: 6;
                            preferred-width: 0;
                            min-width: 0;
                            background: Theme.card_bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.border_color;
                            VerticalLayout {
                                min-width: 0;
                                padding: 12px;
                                spacing: 8px;

                                Text {
                                    min-width: 0;
                                    text: root.strings.version_output_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                                }

                                CodeBlock {
                                    vertical-stretch: 1;
                                    text: root.version_text;
                                }
                            }
                        }

                        if (!AppI18n.is-rtl && root.status_text != ""): Rectangle {
                            horizontal-stretch: 4;
                            preferred-width: 0;
                            min-width: 0;
                            background: Theme.card_bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.border_color;
                            VerticalLayout {
                                min-width: 0;
                                padding: 12px;
                                spacing: 8px;

                                Text {
                                    min-width: 0;
                                    text: root.strings.status_output_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                                }

                                CodeBlock {
                                    vertical-stretch: 1;
                                    text: root.status_text;
                                }
                            }
                        }

                        // RTL: Status left, Version right
                        if (AppI18n.is-rtl && root.status_text != ""): Rectangle {
                            horizontal-stretch: 4;
                            preferred-width: 0;
                            min-width: 0;
                            background: Theme.card_bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.border_color;
                            VerticalLayout {
                                min-width: 0;
                                padding: 12px;
                                spacing: 8px;

                                Text {
                                    min-width: 0;
                                    text: root.strings.status_output_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                                }

                                CodeBlock {
                                    vertical-stretch: 1;
                                    text: root.status_text;
                                }
                            }
                        }

                        if (AppI18n.is-rtl && root.version_text != ""): Rectangle {
                            horizontal-stretch: 6;
                            preferred-width: 0;
                            min-width: 0;
                            background: Theme.card_bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.border_color;
                            VerticalLayout {
                                min-width: 0;
                                padding: 12px;
                                spacing: 8px;

                                Text {
                                    min-width: 0;
                                    text: root.strings.version_output_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                                }

                                CodeBlock {
                                    vertical-stretch: 1;
                                    text: root.version_text;
                                }
                            }
                        }
                    }

                    // === Default Version Card ===
                    if (root.wsl_installed): Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.card_bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border_color;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 14px;

                            Text {
                                text: root.strings.default_version_title;
                                font-size: 14px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                font-weight: 500;
                                color: Theme.text_primary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }

                            Divider { }

                            Text {
                                text: root.strings.default_version_desc;
                                font-size: 13px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_secondary;
                                wrap: word-wrap;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }

                            if (!AppI18n.is-rtl): HorizontalLayout {
                                spacing: 8px;
                                alignment: start;

                                ToggleButton {
                                    text: root.strings.version_label_1;
                                    selected: root.default_version == 1;
                                    min-width: 96px;
                                    height: 32px;
                                    clicked => {
                                        root.set_default_version(1);
                                    }
                                }

                                ToggleButton {
                                    text: root.strings.version_label_2;
                                    selected: root.default_version == 2;
                                    min-width: 96px;
                                    height: 32px;
                                    clicked => {
                                        root.set_default_version(2);
                                    }
                                }
                            }
                            if (AppI18n.is-rtl): HorizontalLayout {
                                spacing: 8px;
                                alignment: end;

                                ToggleButton {
                                    text: root.strings.version_label_2;
                                    selected: root.default_version == 2;
                                    min-width: 96px;
                                    height: 32px;
                                    clicked => {
                                        root.set_default_version(2);
                                    }
                                }

                                ToggleButton {
                                    text: root.strings.version_label_1;
                                    selected: root.default_version == 1;
                                    min-width: 96px;
                                    height: 32px;
                                    clicked => {
                                        root.set_default_version(1);
                                    }
                                }
                            }

                            Divider { }

                            CustomCheckBox {
                                checked <=> root.vhdx_sparse_mode;
                                text: root.strings.sparse_mode;
                                toggled => {
                                    root.sparse_mode_toggled();
                                }
                            }
                        }
                    }

                    // === Actions Card (one row per action) ===
                    if (root.wsl_installed): Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.card_bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border_color;
                        VerticalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            padding-top: 8px;
                            padding-bottom: 8px;
                            spacing: 0px;

                            Text {
                                text: root.strings.actions_title;
                                font-size: 14px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                font-weight: 500;
                                color: Theme.text_primary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }

                            Divider { }

                            ActionRow {
                                icon: "\u{E895}";   // Refresh
                                title: root.strings.update_btn;
                                description: root.strings.update_desc;
                                button-text: root.is_updating ? root.strings.updating_btn : root.strings.update_btn;
                                button-style: "primary";
                                enabled: !root.is_updating;
                                clicked => {
                                    root.update_wsl();
                                }
                            }

                            Divider { }

                            ActionRow {
                                icon: "\u{E713}";   // Settings
                                title: root.strings.settings_btn;
                                description: root.strings.settings_desc;
                                button-text: root.strings.settings_btn;
                                button-style: "default";
                                clicked => {
                                    root.open_wsl_settings();
                                }
                            }

                            Divider { }

                            ActionRow {
                                icon: "\u{E74D}";   // Trash
                                title: root.strings.uninstall_btn;
                                description: root.strings.uninstall_desc;
                                button-text: root.strings.uninstall_btn;
                                button-style: "danger";
                                show-shield: true;
                                enabled: !root.is_updating;
                                clicked => {
                                    root.uninstall_wsl();
                                }
                            }
                        }
                    }

                    // === Mount Disk Card ===
                    if (root.wsl_installed): Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.card_bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border_color;
                        opacity: root.mount_running ? 0.7 : 1.0;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 12px;

                            Text {
                                text: root.strings.mount_disk_title;
                                font-size: 14px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                font-weight: 500;
                                color: Theme.text_primary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }

                            Divider { }

                            // Physical disks selector
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: AppI18n.is-rtl ? end : start;
                                Text {
                                    text: root.strings.physical_disk_label;
                                    font-size: 13px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    color: Theme.text_secondary;
                                    vertical-alignment: center;
                                }

                                Rectangle {
                                    border-radius: 4px;
                                    background: Theme.hover_bg;
                                    HorizontalLayout {
                                        padding-left: 6px;
                                        padding-right: 6px;
                                        padding-top: 2px;
                                        padding-bottom: 2px;
                                        spacing: 4px;
                                        alignment: center;
                                        Text {
                                            text: "\u{E946}";
                                            font-size: 11px;
                                            font-family: Theme.icon_font;
                                            color: Theme.text_secondary;
                                            vertical-alignment: center;
                                        }

                                        Text {
                                            text: root.strings.usb_mount_hint;
                                            font-size: 11px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            color: Theme.text_secondary;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }

                            if (!AppI18n.is-rtl): HorizontalLayout {
                                spacing: 8px;
                                CustomComboBox {
                                    horizontal-stretch: 1;
                                    min-width: 200px;
                                    model: root.physical_disks;
                                    current-index: 0;
                                    enabled: !root.mount_running;
                                    selected(index) => {
                                        if (index >= 0 && index < root.physical_disks_paths.length) {
                                            root.disk_path = root.physical_disks_paths[index];
                                            root.disk_mount_name = root.physical_disks_names[index];
                                        }
                                    }
                                }

                                CustomButton {
                                    text: root.strings.refresh_disks_btn;
                                    icon: "\u{E72C}";
                                    height: 32px;
                                    enabled: !root.mount_running;
                                    clicked => {
                                        root.refresh_physical_disks();
                                    }
                                }
                            }
                            if (AppI18n.is-rtl): HorizontalLayout {
                                spacing: 8px;
                                CustomButton {
                                    text: root.strings.refresh_disks_btn;
                                    icon: "\u{E72C}";
                                    height: 32px;
                                    enabled: !root.mount_running;
                                    clicked => {
                                        root.refresh_physical_disks();
                                    }
                                }

                                CustomComboBox {
                                    horizontal-stretch: 1;
                                    min-width: 200px;
                                    model: root.physical_disks;
                                    current-index: 0;
                                    enabled: !root.mount_running;
                                    selected(index) => {
                                        if (index >= 0 && index < root.physical_disks_paths.length) {
                                            root.disk_path = root.physical_disks_paths[index];
                                            root.disk_mount_name = root.physical_disks_names[index];
                                        }
                                    }
                                }
                            }

                            // Checkboxes row
                            HorizontalLayout {
                                spacing: 16px;
                                alignment: AppI18n.is-rtl ? end : start;
                                CustomCheckBox {
                                    checked <=> root.disk_is_bare;
                                    text: root.strings.bare_mount_label;
                                    enabled: !root.mount_running;
                                }
                            }

                            // Disk path label
                            Text {
                                text: root.strings.disk_path_label;
                                font-size: 13px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_secondary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }

                            // Disk path input + Browse button
                            if (!AppI18n.is-rtl): HorizontalLayout {
                                spacing: 8px;
                                CustomLineEdit {
                                    horizontal-stretch: 1;
                                    text <=> root.disk_path;
                                    placeholder-text: root.strings.disk_path_placeholder;
                                    enabled: !root.mount_running;
                                }

                                CustomButton {
                                    icon: "\u{E8B7}";
                                    icon-only: true;
                                    height: 32px;
                                    enabled: !root.mount_running;
                                    clicked => {
                                        root.browse_vhd();
                                    }
                                }
                            }
                            if (AppI18n.is-rtl): HorizontalLayout {
                                spacing: 8px;
                                CustomButton {
                                    icon: "\u{E8B7}";
                                    icon-only: true;
                                    height: 32px;
                                    enabled: !root.mount_running;
                                    clicked => {
                                        root.browse_vhd();
                                    }
                                }

                                CustomLineEdit {
                                    horizontal-stretch: 1;
                                    text <=> root.disk_path;
                                    placeholder-text: root.strings.disk_path_placeholder;
                                    enabled: !root.mount_running;
                                }
                            }

                            // Optional fields: Name, Type (2 columns)
                            if (!AppI18n.is-rtl): HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;
                                    Text {
                                        text: root.strings.mount_name_label;
                                        font-size: 13px * LayoutConstants.font-scale;
                                        font-family: Theme.default_font;
                                        color: Theme.text_secondary;
                                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                                    }

                                    CustomLineEdit {
                                        horizontal-stretch: 1;
                                        text <=> root.disk_mount_name;
                                        enabled: !root.mount_running;
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;
                                    Text {
                                        text: root.strings.filesystem_label;
                                        font-size: 13px * LayoutConstants.font-scale;
                                        font-family: Theme.default_font;
                                        color: Theme.text_secondary;
                                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                                    }

                                    CustomLineEdit {
                                        horizontal-stretch: 1;
                                        text <=> root.disk_fs_type;
                                        enabled: !root.mount_running;
                                    }
                                }
                            }
                            if (AppI18n.is-rtl): HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;
                                    Text {
                                        text: root.strings.filesystem_label;
                                        font-size: 13px * LayoutConstants.font-scale;
                                        font-family: Theme.default_font;
                                        color: Theme.text_secondary;
                                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                                    }

                                    CustomLineEdit {
                                        horizontal-stretch: 1;
                                        text <=> root.disk_fs_type;
                                        enabled: !root.mount_running;
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;
                                    Text {
                                        text: root.strings.mount_name_label;
                                        font-size: 13px * LayoutConstants.font-scale;
                                        font-family: Theme.default_font;
                                        color: Theme.text_secondary;
                                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                                    }

                                    CustomLineEdit {
                                        horizontal-stretch: 1;
                                        text <=> root.disk_mount_name;
                                        enabled: !root.mount_running;
                                    }
                                }
                            }

                            // Optional fields: Partition, Options (2 columns)
                            if (!AppI18n.is-rtl): HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;
                                    Text {
                                        text: root.strings.partition_label;
                                        font-size: 13px * LayoutConstants.font-scale;
                                        font-family: Theme.default_font;
                                        color: Theme.text_secondary;
                                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                                    }

                                    CustomLineEdit {
                                        horizontal-stretch: 1;
                                        text <=> root.disk_partition;
                                        placeholder-text: "1";
                                        enabled: !root.mount_running;
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;
                                    Text {
                                        text: root.strings.mount_options_label;
                                        font-size: 13px * LayoutConstants.font-scale;
                                        font-family: Theme.default_font;
                                        color: Theme.text_secondary;
                                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                                    }

                                    CustomLineEdit {
                                        horizontal-stretch: 1;
                                        text <=> root.disk_options;
                                        enabled: !root.mount_running;
                                    }
                                }
                            }
                            if (AppI18n.is-rtl): HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;
                                    Text {
                                        text: root.strings.mount_options_label;
                                        font-size: 13px * LayoutConstants.font-scale;
                                        font-family: Theme.default_font;
                                        color: Theme.text_secondary;
                                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                                    }

                                    CustomLineEdit {
                                        horizontal-stretch: 1;
                                        text <=> root.disk_options;
                                        enabled: !root.mount_running;
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;
                                    Text {
                                        text: root.strings.partition_label;
                                        font-size: 13px * LayoutConstants.font-scale;
                                        font-family: Theme.default_font;
                                        color: Theme.text_secondary;
                                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                                    }

                                    CustomLineEdit {
                                        horizontal-stretch: 1;
                                        text <=> root.disk_partition;
                                        placeholder-text: "1";
                                        enabled: !root.mount_running;
                                    }
                                }
                            }

                            // Mount button (full-width row, right-aligned in LTR)
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: AppI18n.is-rtl ? start : end;
                                CustomButton {
                                    text: root.mount_running ? root.strings.mounting_btn : root.strings.mount_btn;
                                    primary: true;
                                    enabled: !root.mount_running && root.disk_path != "";
                                    height: 32px;
                                    clicked => {
                                        root.mount_disk();
                                    }
                                }
                            }

                            // Mount output (if any)
                            if (root.mount_output != ""): CodeBlock {
                                text: root.mount_output;
                            }
                        }
                    }

                    // === Mounted Disks Card ===
                    if (root.wsl_installed): Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.card_bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border_color;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 12px;

                            if (!AppI18n.is-rtl): HorizontalLayout {
                                spacing: 8px;
                                alignment: space-between;

                                Text {
                                    text: root.strings.mounted_disks_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    vertical-alignment: center;
                                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                                }

                                HorizontalLayout {
                                    spacing: 6px;
                                    CustomButton {
                                        text: root.strings.refresh_disks_btn;
                                        icon: "\u{E72C}";
                                        height: 28px;
                                        clicked => {
                                            root.refresh_mounted_disks();
                                        }
                                    }

                                    CustomButton {
                                        text: root.strings.unmount_all_btn;
                                        danger: true;
                                        ghost: true;
                                        height: 28px;
                                        clicked => {
                                            root.unmount_all_disks();
                                        }
                                    }
                                }
                            }
                            if (AppI18n.is-rtl): HorizontalLayout {
                                spacing: 8px;
                                alignment: space-between;

                                HorizontalLayout {
                                    spacing: 6px;
                                    CustomButton {
                                        text: root.strings.unmount_all_btn;
                                        danger: true;
                                        ghost: true;
                                        height: 28px;
                                        clicked => {
                                            root.unmount_all_disks();
                                        }
                                    }

                                    CustomButton {
                                        text: root.strings.refresh_disks_btn;
                                        icon: "\u{E72C}";
                                        height: 28px;
                                        clicked => {
                                            root.refresh_mounted_disks();
                                        }
                                    }
                                }

                                Text {
                                    text: root.strings.mounted_disks_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    vertical-alignment: center;
                                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                                }
                            }

                            if (root.mounted_disks.length == 0): EmptyState {
                                icon: "\u{E7C3}";
                                text: root.strings.no_mounted_disks;
                                hint: root.strings.no_mounted_disks_hint;
                            }

                            // Mounted disk list
                            VerticalLayout {
                                spacing: 6px;
                                for disk in root.mounted_disks: Rectangle {
                                    height: 40px;
                                    border-radius: 4px;
                                    background: Theme.surface_subtle;
                                    border-width: 1px;
                                    border-color: Theme.border_color;
                                    if (!AppI18n.is-rtl): HorizontalLayout {
                                        padding-left: 12px;
                                        padding-right: 12px;
                                        spacing: 8px;
                                        alignment: space-between;

                                        Text {
                                            text: disk;
                                            font-size: 13px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            color: Theme.text_primary;
                                            vertical-alignment: center;
                                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            CustomButton {
                                                text: root.strings.unmount_btn;
                                                ghost: true;
                                                danger: true;
                                                height: 28px;
                                                clicked => {
                                                    root.unmount_disk(disk);
                                                }
                                            }
                                        }
                                    }
                                    if (AppI18n.is-rtl): HorizontalLayout {
                                        padding-left: 12px;
                                        padding-right: 12px;
                                        spacing: 8px;
                                        alignment: space-between;

                                        VerticalLayout {
                                            alignment: center;
                                            CustomButton {
                                                text: root.strings.unmount_btn;
                                                ghost: true;
                                                danger: true;
                                                height: 28px;
                                                clicked => {
                                                    root.unmount_disk(disk);
                                                }
                                            }
                                        }

                                        Text {
                                            text: disk;
                                            font-size: 13px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            color: Theme.text_primary;
                                            vertical-alignment: center;
                                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if (flick.viewport-height > flick.height): CustomScrollbar {
        x: AppI18n.is-rtl ? 2px : parent.width - 8px;
        y: 0;
        width: 8px;
        height: 100%;
        maximum: flick.viewport-height - flick.height;
        page_size: flick.height;
        value: -flick.viewport-y;
        scroll_to(v) => {
            flick.viewport-y = -v;
        }
    }
}
