import {
    Theme,
    AppI18n,
    WslManageStrings,
    LayoutConstants,
} from "../theme.slint";
import { CustomButton, CustomCheckBox, CustomComboBox, CustomLineEdit } from "../components/form_widgets.slint";
import { CustomScrollbar } from "../components/scrollbar.slint";

// Status badge component
component StatusBadge inherits Rectangle {
    in property <string> text: "";
    in property <color> bg-color: #10b981;
    height: 24px;
    border-radius: 12px;
    background: root.bg-color.with-alpha(20%);
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        height: 100%;
        alignment: center;
        // Dot indicator
        Rectangle {
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: root.bg-color;
            y: (24px - 6px) / 2;
        }
        Text {
            text: root.text;
            font-size: 12px * LayoutConstants.font-scale;
            font-family: Theme.default_font;
            color: root.bg-color;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}

// Code block component for displaying command output
component CodeBlock inherits Rectangle {
    in property <string> text: "";
    min-width: 0;
    background: Theme.dark_mode ? #1e1e2e : #f6f8fa;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.border_color;
    clip: true;

    VerticalLayout {
        min-width: 0;
        padding: 12px;
        padding-left: AppI18n.is-rtl ? 12px : 16px;
        padding-right: AppI18n.is-rtl ? 16px : 12px;
        Text {
            min-width: 0;
            text: root.text;
            font-size: 12.5px * LayoutConstants.font-scale;
            font-family: Theme.default_font;
            color: Theme.dark_mode ? #cdd6f4 : #24292f;
            horizontal-alignment: AppI18n.is-rtl ? right : left;
        }
    }
}

export component WslManageView inherits Rectangle {
    // Static labels (i18n)
    in property <WslManageStrings> strings;

    // Dynamic data from backend
    in property <bool> wsl_installed: false;
    in property <int> default_version: 2;
    in property <bool> has_running_instances: false;
    in property <bool> has_instances: false;
    in property <bool> is_updating: false;
    in property <string> version_text: "";
    in property <string> status_text: "";
    in property <string> default_distro_name;

    in-out property <bool> vhdx_sparse_mode: false;

    // Disk mount properties
    in-out property <string> disk_path: "";
    in-out property <bool> disk_is_vhd: false;
    in-out property <bool> disk_is_bare: false;
    in-out property <string> disk_mount_name: "";
    in-out property <string> disk_fs_type: "ext4";
    in-out property <string> disk_partition: "";
    in-out property <string> disk_options: "";
    in property <bool> mount_running: false;
    in property <string> mount_output: "";
    in property <bool> mount_is_error: false;
    in property <[string]> mounted_disks: [];
    in property <[string]> physical_disks: [];
    in property <[string]> physical_disks_paths: [];
    in property <[string]> physical_disks_names: [];

    // Callbacks
    callback install_wsl();
    callback start_wsl();
    callback update_wsl();
    callback shutdown_all();
    callback set_default_version(int);
    callback uninstall_wsl();
    callback open_wsl_settings();
    callback sparse_mode_toggled();
    callback mount_disk();
    callback unmount_disk(string);
    callback unmount_all_disks();
    callback refresh_mounted_disks();
    callback refresh_physical_disks();
    callback browse_vhd();

    VerticalLayout {
        spacing: 12px;
        padding-left: AppI18n.is-rtl ? 16px : 4px;
        padding-right: AppI18n.is-rtl ? 4px : 16px;
        padding-top: 8px;
        padding-bottom: 8px;

        Rectangle {
            clip: true;
            vertical-stretch: 1;

            flick := Flickable {
                viewport-height: content-layout.preferred-height;
                width: parent.width;
                height: 100%;

                content-layout := VerticalLayout {
                    width: parent.width;
                    spacing: 12px;

                    // === Status Header Card ===
                    Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.card_bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border_color;
                        VerticalLayout {
                            padding: 12px;
                            spacing: 10px;

                            // Title row with equidistant spacing between the 3 components
                            HorizontalLayout {
                                spacing: 10px;
                                alignment: center;
                                horizontal-stretch: 1;
                                Rectangle { horizontal-stretch: 1; }
                                Text {
                                    text: root.strings.status_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                                if (root.wsl_installed): Rectangle {
                                    height: 28px;
                                    VerticalLayout {
                                        alignment: center;
                                        StatusBadge {
                                            text: root.has_running_instances ? root.strings.status_running : root.strings.status_stopped;
                                            bg-color: root.has_running_instances ? #10b981 : #f59e0b;
                                        }
                                    }
                                }
                                if (!root.wsl_installed): Rectangle {
                                    height: 28px;
                                    VerticalLayout {
                                        alignment: center;
                                        StatusBadge {
                                            text: root.strings.status_not_installed;
                                            bg-color: #ef4444;
                                        }
                                    }
                                }
                                Rectangle { horizontal-stretch: 1; }
                                // Not installed → install icon
                                if (!root.wsl_installed): Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    border-radius: 6px;
                                    background: touch_install.has-hover ? Theme.accent.with-alpha(25%) : Theme.accent.with-alpha(12%);
                                    Text {
                                        text: "\u{E945}"; // Shield/Download
                                        font-size: 14px;
                                        font-family: Theme.icon_font;
                                        color: Theme.accent;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    touch_install := TouchArea { clicked => { root.install_wsl(); } }
                                }
                                // Running → stop icon
                                if (root.wsl_installed && root.has_running_instances): Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    border-radius: 6px;
                                    background: touch_stop.has-hover ? #ef4444.with-alpha(25%) : #ef4444.with-alpha(12%);
                                    Text {
                                        text: "\u{E769}"; // Stop
                                        font-size: 12px;
                                        font-family: Theme.icon_font;
                                        color: #ef4444;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    touch_stop := TouchArea { clicked => { root.shutdown_all(); } }
                                    // Tooltip
                                    Rectangle {
                                        visible: touch_stop.has-hover;
                                        background: Theme.dark_mode ? #2D2D30 : #FFFFFF;
                                        border-color: Theme.border_color;
                                        border-width: 1px;
                                        border-radius: 4px;
                                        z: 100;
                                        x: parent.width + 4px;
                                        y: (parent.height - self.height) / 2;
                                        width: tt_text.width + 12px;
                                        height: tt_text.height + 6px;
                                        tt_text := Text {
                                            text: root.strings.shutdown_btn_tooltip;
                                            color: Theme.text_primary;
                                            font-size: 11px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                                // Installed but stopped → play icon
                                if (root.wsl_installed && !root.has_running_instances && root.has_instances): Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    border-radius: 6px;
                                    background: touch_start.has-hover ? #10b981.with-alpha(25%) : #10b981.with-alpha(12%);
                                    Text {
                                        text: "\u{E768}"; // Play
                                        font-size: 14px;
                                        font-family: Theme.icon_font;
                                        color: #10b981;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    touch_start := TouchArea { clicked => { root.start_wsl(); } }
                                    // Tooltip
                                    Rectangle {
                                        visible: touch_start.has-hover;
                                        background: Theme.dark_mode ? #2D2D30 : #FFFFFF;
                                        border-color: Theme.border_color;
                                        border-width: 1px;
                                        border-radius: 4px;
                                        z: 100;
                                        x: parent.width + 4px;
                                        y: (parent.height - self.height) / 2;
                                        width: tt_start_text.width + 12px;
                                        height: tt_start_text.height + 6px;
                                        tt_start_text := Text {
                                            text: AppI18n.t("wsl_manage.start_btn_tooltip", [root.default_distro_name]);
                                            color: Theme.text_primary;
                                            font-size: 11px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // === Version & Status Info side by side ===
                    if (root.wsl_installed && (root.version_text != "" || root.status_text != "")): HorizontalLayout {
                        spacing: 12px;
                        if (root.version_text != ""): Rectangle {
                            horizontal-stretch: 6;
                            preferred-width: 0;
                            min-width: 0;
                            background: Theme.card_bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.border_color;
                            VerticalLayout {
                                min-width: 0;
                                padding: 12px;
                                spacing: 8px;

                                Text {
                                    min-width: 0;
                                    text: root.strings.version_output_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                                }

                                CodeBlock {
                                    vertical-stretch: 1;
                                    text: root.version_text;
                                }
                            }
                        }

                        if (root.status_text != ""): Rectangle {
                            horizontal-stretch: 4;
                            preferred-width: 0;
                            min-width: 0;
                            background: Theme.card_bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.border_color;
                            VerticalLayout {
                                min-width: 0;
                                padding: 12px;
                                spacing: 8px;

                                Text {
                                    min-width: 0;
                                    text: root.strings.status_output_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                                }

                                CodeBlock {
                                    vertical-stretch: 1;
                                    text: root.status_text;
                                }
                            }
                        }
                    }

                    // === Default Version Card ===
                    if (root.wsl_installed): Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.card_bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border_color;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 14px;

                            Text {
                                text: root.strings.default_version_title;
                                font-size: 14px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                font-weight: 500;
                                color: Theme.text_primary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }

                            Rectangle {
                                height: 1px;
                                background: Theme.border_color;
                            }

                            Text {
                                text: root.strings.default_version_desc;
                                font-size: 13px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_secondary;
                                wrap: word-wrap;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: AppI18n.is-rtl ? end : start;

                                Rectangle {
                                    width: 80px;
                                    height: 32px;
                                    border-radius: 4px;
                                    border-width: 1px;
                                    border-color: root.default_version == 1 ? Theme.accent : Theme.input_border;
                                    background: root.default_version == 1 ? Theme.accent.with-alpha(15%) : Theme.input_bg;
                                    HorizontalLayout {
                                        alignment: center;
                                        Text {
                                            text: root.strings.version_label_1;
                                            font-size: 13px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            font-weight: root.default_version == 1 ? 700 : 400;
                                            color: root.default_version == 1 ? Theme.accent : Theme.text_secondary;
                                            vertical-alignment: center;
                                        }
                                    }
                                    TouchArea {
                                        clicked => {
                                            root.set_default_version(1);
                                        }
                                    }
                                }

                                Rectangle {
                                    width: 80px;
                                    height: 32px;
                                    border-radius: 4px;
                                    border-width: 1px;
                                    border-color: root.default_version == 2 ? Theme.accent : Theme.input_border;
                                    background: root.default_version == 2 ? Theme.accent.with-alpha(15%) : Theme.input_bg;
                                    HorizontalLayout {
                                        alignment: center;
                                        Text {
                                            text: root.strings.version_label_2;
                                            font-size: 13px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            font-weight: root.default_version == 2 ? 700 : 400;
                                            color: root.default_version == 2 ? Theme.accent : Theme.text_secondary;
                                            vertical-alignment: center;
                                        }
                                    }
                                    TouchArea {
                                        clicked => {
                                            root.set_default_version(2);
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                height: 1px;
                                background: Theme.border_color;
                            }

                            CustomCheckBox { checked <=> root.vhdx_sparse_mode; text: root.strings.sparse_mode; toggled => { root.sparse_mode_toggled(); } }
                        }
                    }

                    // === Actions Card ===
                    if (root.wsl_installed): Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.card_bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border_color;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 14px;

                            Text {
                                text: root.strings.actions_title;
                                font-size: 14px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                font-weight: 500;
                                color: Theme.text_primary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }

                            Rectangle {
                                height: 1px;
                                background: Theme.border_color;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: AppI18n.is-rtl ? end : start;

                                CustomButton {
                                    text: root.strings.settings_btn;
                                    height: 32px;
                                    clicked => {
                                        root.open_wsl_settings();
                                    }
                                }

                                CustomButton {
                                    text: root.is_updating ? root.strings.updating_btn : root.strings.update_btn;
                                    primary: true;
                                    enabled: !root.is_updating;
                                    height: 32px;
                                    clicked => {
                                        root.update_wsl();
                                    }
                                }

                                CustomButton {
                                    text: root.strings.uninstall_btn;
                                    danger: true;
                                    show-shield: true;
                                    enabled: !root.is_updating;
                                    height: 32px;
                                    clicked => {
                                        root.uninstall_wsl();
                                    }
                                }
                            }
                        }
                    }

                    // === Disk Management Card ===
                    if (root.wsl_installed): Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.card_bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border_color;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 14px;

                            Text {
                                text: root.strings.disk_management_title;
                                font-size: 14px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                font-weight: 500;
                                color: Theme.text_primary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }

                            Rectangle {
                                height: 1px;
                                background: Theme.border_color;
                            }

                            // === Mount Form ===
                            VerticalLayout {
                                spacing: 10px;

                                // Physical disks selector
                                HorizontalLayout {
                                    spacing: 4px;
                                    alignment: AppI18n.is-rtl ? end : start;
                                    Text {
                                        text: root.strings.physical_disk_label;
                                        font-size: 12px * LayoutConstants.font-scale;
                                        font-family: Theme.default_font;
                                        color: Theme.text_secondary;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        border-radius: 4px;
                                        background: Theme.hover_bg;
                                        HorizontalLayout {
                                            padding-left: 6px;
                                            padding-right: 6px;
                                            padding-top: 2px;
                                            padding-bottom: 2px;
                                            spacing: 4px;
                                            Text {
                                                text: "\u{E946}";
                                                font-size: 11px;
                                                font-family: Theme.icon_font;
                                                color: Theme.text_secondary;
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: root.strings.usb_mount_hint;
                                                font-size: 11px * LayoutConstants.font-scale;
                                                font-family: Theme.default_font;
                                                color: Theme.text_secondary;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    CustomComboBox {
                                        horizontal-stretch: 1;
                                        model: root.physical_disks;
                                        current-index: 0;
                                        enabled: !root.mount_running;
                                        selected(index) => {
                                            if (index >= 0 && index < root.physical_disks_paths.length) {
                                                root.disk_path = root.physical_disks_paths[index];
                                                root.disk_mount_name = root.physical_disks_names[index];
                                            }
                                        }
                                    }
                                    CustomButton {
                                        text: root.strings.refresh_disks_btn;
                                        width: 70px;
                                        enabled: !root.mount_running;
                                        clicked => { root.refresh_physical_disks(); }
                                    }
                                }

                                // Checkboxes row
                                HorizontalLayout {
                                    spacing: 16px;
                                    alignment: AppI18n.is-rtl ? end : start;
                                    CustomCheckBox {
                                        checked <=> root.disk_is_bare;
                                        text: root.strings.bare_mount_label;
                                        enabled: !root.mount_running;
                                    }
                                }

                                // Disk path label
                                Text {
                                    text: root.strings.disk_path_label;
                                    font-size: 12px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    color: Theme.text_secondary;
                                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                                }

                                // Disk path input + Browse button
                                HorizontalLayout {
                                    spacing: 8px;
                                    CustomLineEdit {
                                        horizontal-stretch: 1;
                                        text <=> root.disk_path;
                                        placeholder-text: root.strings.disk_path_placeholder;
                                        enabled: !root.mount_running;
                                    }
                                    Rectangle {
                                        width: 32px;
                                        height: 32px;
                                        border-radius: 4px;
                                        background: browse_touch.has-hover ? Theme.hover_bg : Theme.input_bg;
                                        border-width: 1px;
                                        border-color: Theme.input_border;
                                        Text {
                                            text: "\u{E8B7}"; // FolderOpen icon
                                            font-size: 14px;
                                            font-family: Theme.icon_font;
                                            color: Theme.text_secondary;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                        browse_touch := TouchArea {
                                            enabled: !root.mount_running;
                                            clicked => { root.browse_vhd(); }
                                        }
                                    }
                                }

                                // Optional fields: Name, Type, Partition, Options (2 columns)
                                HorizontalLayout {
                                    spacing: 10px;
                                    VerticalLayout {
                                        width: 50%;
                                        spacing: 4px;
                                        Text {
                                            text: root.strings.mount_name_label;
                                            font-size: 12px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            color: Theme.text_secondary;
                                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                                        }
                                        CustomLineEdit {
                                            text <=> root.disk_mount_name;
                                            enabled: !root.mount_running;
                                        }
                                    }
                                    VerticalLayout {
                                        width: 50%;
                                        spacing: 4px;
                                        Text {
                                            text: root.strings.filesystem_label;
                                            font-size: 12px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            color: Theme.text_secondary;
                                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                                        }
                                        CustomLineEdit {
                                            text <=> root.disk_fs_type;
                                            enabled: !root.mount_running;
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 10px;
                                    VerticalLayout {
                                        width: 50%;
                                        spacing: 4px;
                                        Text {
                                            text: root.strings.partition_label;
                                            font-size: 12px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            color: Theme.text_secondary;
                                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                                        }
                                        CustomLineEdit {
                                            text <=> root.disk_partition;
                                            placeholder-text: "1";
                                            enabled: !root.mount_running;
                                        }
                                    }
                                    VerticalLayout {
                                        width: 50%;
                                        spacing: 4px;
                                        Text {
                                            text: root.strings.mount_options_label;
                                            font-size: 12px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            color: Theme.text_secondary;
                                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                                        }
                                        CustomLineEdit {
                                            text <=> root.disk_options;
                                            enabled: !root.mount_running;
                                        }
                                    }
                                }

                                // Mount button
                                HorizontalLayout {
                                    alignment: AppI18n.is-rtl ? end : start;
                                    CustomButton {
                                        text: root.mount_running ? root.strings.mounting_btn : root.strings.mount_btn;
                                        primary: true;
                                        enabled: !root.mount_running && root.disk_path != "";
                                        height: 32px;
                                        clicked => { root.mount_disk(); }
                                    }
                                }
                            }

                            // Mount output
                            if (root.mount_output != ""): Rectangle {
                                height: 1px;
                                background: Theme.border_color;
                            }
                            if (root.mount_output != ""): CodeBlock {
                                text: root.mount_output;
                            }

                            Rectangle {
                                height: 1px;
                                background: Theme.border_color;
                            }

                            // === Mounted Disks Section ===
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: space-between;

                                Text {
                                    text: root.strings.mounted_disks_title;
                                    font-size: 14px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    font-weight: 500;
                                    color: Theme.text_primary;
                                    vertical-alignment: center;
                                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                                }

                                HorizontalLayout {
                                    spacing: 6px;
                                    alignment: AppI18n.is-rtl ? start : end;
                                    CustomButton {
                                        text: root.strings.refresh_disks_btn;
                                        height: 28px;
                                        clicked => { root.refresh_mounted_disks(); }
                                    }
                                    CustomButton {
                                        text: root.strings.unmount_all_btn;
                                        danger: true;
                                        height: 28px;
                                        clicked => { root.unmount_all_disks(); }
                                    }
                                }
                            }

                            if (root.mounted_disks.length == 0): Text {
                                text: root.strings.no_mounted_disks;
                                font-size: 13px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_secondary;
                                horizontal-alignment: AppI18n.is-rtl ? right : left;
                            }

                            // Mounted disk list
                            VerticalLayout {
                                spacing: 6px;
                                for disk in root.mounted_disks: Rectangle {
                                    height: 36px;
                                    border-radius: 4px;
                                    background: Theme.dark_mode ? #252526 : #F8F8F8;
                                    border-width: 1px;
                                    border-color: Theme.border_color;
                                    HorizontalLayout {
                                        padding-left: 12px;
                                        padding-right: 12px;
                                        spacing: 8px;
                                        alignment: space-between;

                                        Text {
                                            text: disk;
                                            font-size: 13px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            color: Theme.text_primary;
                                            vertical-alignment: center;
                                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                                            overflow: elide;
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 60px;
                                                height: 24px;
                                                border-radius: 4px;
                                                background: unmount_touch.has-hover ? #ef4444.with-alpha(25%) : #ef4444.with-alpha(10%);
                                                Text {
                                                    text: root.strings.unmount_btn;
                                                    font-size: 11px * LayoutConstants.font-scale;
                                                    font-family: Theme.default_font;
                                                    color: #ef4444;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                                unmount_touch := TouchArea {
                                                    clicked => { root.unmount_disk(disk); }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }


                }
            }
        }
    }  

    if (flick.viewport-height > flick.height): CustomScrollbar {
        x: AppI18n.is-rtl ? 2px : parent.width - 8px;
        y: 0; width: 8px; height: 100%;
        maximum: flick.viewport-height - flick.height;
        page_size: flick.height;
        value: -flick.viewport-y;
        scroll_to(v) => { flick.viewport-y = -v; }
    }
}
