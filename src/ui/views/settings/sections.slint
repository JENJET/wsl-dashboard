import {
    Theme,
    AppI18n,
    SettingsStrings,
    LayoutConstants,
} from "../../theme.slint";
import {
    CustomLineEdit,
    CustomComboBox,
    CustomCheckBox,
    CustomButton,
} from "../../components/form_widgets.slint";
import { ActionIcon } from "../../components/common.slint";

export component GeneralSettingsSection inherits VerticalLayout {
    in property <SettingsStrings> strings;
    in-out property <int> selected_language_index;
    in-out property <int> selected_check_update_index;
    in property <[string]> language_options;
    in property <[string]> check_update_options;
    spacing: 16px;

    // 1. Software language and Update check
    Rectangle {
        z: 50;
        height: lang-grid.preferred-height;
        lang-grid := GridLayout {
            spacing: 12px;
            if (!AppI18n.is-rtl): Row {
                VerticalLayout {
                    horizontal-stretch: 1;
                    preferred-width: 0;
                    min-width: 0;
                    spacing: 10px;
                    Text {
                        text: root.strings.language;
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: Theme.text_secondary;
                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                    }

                    CustomComboBox {
                        model: root.language_options;
                        current-index <=> root.selected_language_index;
                        height: 32px;
                    }
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    preferred-width: 0;
                    min-width: 0;
                    spacing: 10px;
                    Text {
                        text: root.strings.auto_update;
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: Theme.text_secondary;
                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                    }

                    CustomComboBox {
                        model: root.check_update_options;
                        current-index <=> root.selected_check_update_index;
                        height: 32px;
                        dropdown-height: 100px;
                    }
                }
            }
            if (AppI18n.is-rtl): Row {
                VerticalLayout {
                    horizontal-stretch: 1;
                    preferred-width: 0;
                    min-width: 0;
                    spacing: 10px;
                    Text {
                        text: root.strings.auto_update;
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: Theme.text_secondary;
                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                    }

                    CustomComboBox {
                        model: root.check_update_options;
                        current-index <=> root.selected_check_update_index;
                        height: 32px;
                        dropdown-height: 100px;
                    }
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    preferred-width: 0;
                    min-width: 0;
                    spacing: 10px;
                    Text {
                        text: root.strings.language;
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: Theme.text_secondary;
                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                    }

                    CustomComboBox {
                        model: root.language_options;
                        current-index <=> root.selected_language_index;
                        height: 32px;
                    }
                }
            }
        }
    }
}

export component PathSettingsSection inherits VerticalLayout {
    in property <SettingsStrings> strings;
    in-out property <string> distro_location;
    in-out property <string> logs_location;
    callback select_distro_folder();
    callback select_logs_folder();
    spacing: 16px;
    Text {
        text: root.strings.log_path;
        font-size: 13px * LayoutConstants.font-scale;
        font-family: Theme.default_font;
        color: Theme.text_secondary;
        horizontal-alignment: AppI18n.is-rtl ? right : left;
    }

    HorizontalLayout {
        spacing: 6px;
        if (AppI18n.is-rtl): CustomButton {
            text: root.strings.select_folder;
            height: 32px;
            clicked => {
                root.select_logs_folder();
            }
        }
        Rectangle {
            horizontal-stretch: 1;
            height: 32px;
            border-radius: 4px;
            border-width: 1px;
            border-color: Theme.border_color;
            background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
            TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.select_logs_folder();
                }
            }

            CustomLineEdit {
                text: root.logs_location;
                enabled: false;
                width: parent.width;
                height: parent.height;
            }
        }

        if (!AppI18n.is-rtl): CustomButton {
            text: root.strings.select_folder;
            height: 32px;
            clicked => {
                root.select_logs_folder();
            }
        }
    }

    Rectangle {
        height: 1px;
        background: Theme.border_color;
    }

    Text {
        text: root.strings.install_dir;
        font-size: 13px * LayoutConstants.font-scale;
        font-family: Theme.default_font;
        color: Theme.text_secondary;
        horizontal-alignment: AppI18n.is-rtl ? right : left;
    }

    HorizontalLayout {
        spacing: 8px;
        if (AppI18n.is-rtl): CustomButton {
            text: root.strings.select_folder;
            height: 32px;
            clicked => {
                root.select_distro_folder();
            }
        }
        Rectangle {
            horizontal-stretch: 1;
            height: 32px;
            border-radius: 4px;
            border-width: 1px;
            border-color: Theme.border_color;
            background: Theme.dark_mode ? #1E1E1E : #F3F3F3;
            TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.select_distro_folder();
                }
            }

            CustomLineEdit {
                text: root.distro_location;
                enabled: false;
                width: parent.width;
                height: parent.height;
            }
        }

        if (!AppI18n.is-rtl): CustomButton {
            text: root.strings.select_folder;
            height: 32px;
            clicked => {
                root.select_distro_folder();
            }
        }
    }
}

export component TerminalSettingsSection inherits Rectangle {
    in property <SettingsStrings> strings;
    in property <[string]> emulator_options;
    in property <[bool]> emulator_disabled;
    in-out property <int> selected_emulator_index: 0;
    in-out property <bool> show_custom: false;
    in-out property <string> custom_path;
    in-out property <string> custom_args;
    in property <string> validation_result;
    in property <bool> validation_ok: false;
    callback path_browse();
    callback refresh_terminals();

    // User-defined terminal preset management
    in property <[string]> user_preset_names;
    in property <string> user_preset_form_title;
    in-out property <bool> show_user_preset_form: false;
    in-out property <string> user_preset_form_name;
    in-out property <string> user_preset_form_path;
    in-out property <string> user_preset_form_args;
    in property <string> user_preset_form_error;
    in-out property <string> user_preset_original_name;
    callback edit_user_preset(string);
    callback delete_user_preset(string);
    callback save_user_preset(string, string, string, string);
    callback cancel_user_preset_form;
    callback add_user_preset;
    callback user_preset_path_browse;
    background: Theme.card_bg;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.border_color;
    VerticalLayout {
        padding: 12px;
        spacing: 12px;
        Text {
            text: AppI18n.t("settings.terminal_emulator", [AppI18n.version]);
            font-size: 13px * LayoutConstants.font-scale;
            font-family: Theme.default_font;
            color: Theme.text_secondary;
        }

        VerticalLayout {
            spacing: 8px;
            if (!AppI18n.is-rtl): HorizontalLayout {
                spacing: 6px;
                CustomComboBox {
                    model: root.emulator_options;
                    item-disabled: root.emulator_disabled;
                    current-index <=> root.selected_emulator_index;
                    height: 32px;
                    dropdown-height: 200px;
                    horizontal-stretch: 1;
                }

                ActionIcon {
                    icon: "\u{E72C}";
                    is_font_icon: true;
                    tooltip: AppI18n.t("settings.refresh_terminals", [AppI18n.version]);
                    width: 32px;
                    height: 32px;
                    clicked => {
                        root.refresh_terminals();
                    }
                }
            }
            if (AppI18n.is-rtl): HorizontalLayout {
                spacing: 6px;
                ActionIcon {
                    icon: "\u{E72C}";
                    is_font_icon: true;
                    tooltip: AppI18n.t("settings.refresh_terminals", [AppI18n.version]);
                    width: 32px;
                    height: 32px;
                    clicked => {
                        root.refresh_terminals();
                    }
                }

                CustomComboBox {
                    model: root.emulator_options;
                    item-disabled: root.emulator_disabled;
                    current-index <=> root.selected_emulator_index;
                    height: 32px;
                    dropdown-height: 200px;
                    horizontal-stretch: 1;
                }
            }
            if root.validation_result != "": Text {
                text: root.validation_result;
                font-size: 12px * LayoutConstants.font-scale;
                font-family: Theme.default_font;
                color: root.validation_ok ? #2ecc71 : #ff3333;
            }
            if root.show_custom: VerticalLayout {
                spacing: 8px;
                Text {
                    text: AppI18n.t("settings.terminal_custom_path", [AppI18n.version]);
                    font-size: 13px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    color: Theme.text_secondary;
                }

                if (!AppI18n.is-rtl): HorizontalLayout {
                    spacing: 6px;
                    CustomLineEdit {
                        text <=> root.custom_path;
                        horizontal-stretch: 1;
                        placeholder-text: "C:\\Windows\\system32\\cmd.exe";
                    }

                    CustomButton {
                        text: "...";
                        width: 40px;
                        height: 32px;
                        clicked => {
                            root.path_browse();
                        }
                    }
                }
                if (AppI18n.is-rtl): HorizontalLayout {
                    spacing: 6px;
                    CustomButton {
                        text: "...";
                        width: 40px;
                        height: 32px;
                        clicked => {
                            root.path_browse();
                        }
                    }

                    CustomLineEdit {
                        text <=> root.custom_path;
                        horizontal-stretch: 1;
                        placeholder-text: "C:\\Windows\\system32\\cmd.exe";
                    }
                }
                Text {
                    text: AppI18n.t("settings.terminal_custom_args", [AppI18n.version]);
                    font-size: 13px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    color: Theme.text_secondary;
                }

                CustomLineEdit {
                    text <=> root.custom_args;
                    placeholder-text: "wsl -d {distro} --cd {dir}";
                }

                Text {
                    text: AppI18n.t("settings.terminal_placeholders_hint", [AppI18n.version]);
                    font-size: 11px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    color: Theme.text_secondary;
                }
            }

            // User-defined preset management
            Rectangle {
                height: 1px;
                background: Theme.border_color;
            }

            VerticalLayout {
                spacing: 8px;
                if (!AppI18n.is-rtl): HorizontalLayout {
                    Text {
                        text: AppI18n.t("dialog.terminal.section_custom", [AppI18n.version]);
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: Theme.text_secondary;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    CustomButton {
                        text: AppI18n.t("dialog.terminal.add_preset", [AppI18n.version]);
                        height: 28px;
                        clicked => {
                            root.add_user_preset();
                        }
                    }
                }
                if (AppI18n.is-rtl): HorizontalLayout {
                    CustomButton {
                        text: AppI18n.t("dialog.terminal.add_preset", [AppI18n.version]);
                        height: 28px;
                        clicked => {
                            root.add_user_preset();
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    Text {
                        text: AppI18n.t("dialog.terminal.section_custom", [AppI18n.version]);
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: Theme.text_secondary;
                        vertical-alignment: center;
                    }
                }

                if root.user_preset_names.length > 0: VerticalLayout {
                    spacing: 4px;
                    for name[idx] in root.user_preset_names: Rectangle {
                        border-radius: 4px;
                        background: Theme.input_bg;
                        if (!AppI18n.is-rtl): HorizontalLayout {
                            padding: 8px;
                            spacing: 8px;
                            Text {
                                text: (idx + 1) + ". " + name;
                                font-size: 13px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_primary;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            CustomButton {
                                text: AppI18n.t("dialog.terminal.edit_preset", [AppI18n.version]);
                                height: 26px;
                                clicked => {
                                    root.edit_user_preset(name);
                                }
                            }

                            Rectangle {
                                width: 32px;
                                height: 26px;
                                border-radius: 4px;
                                background: touch.pressed ? #c62828 : (touch.has-hover ? #ff4444 : transparent);
                                border-width: 0px;
                                Text {
                                    text: "\u{D7}";
                                    color: touch.has-hover ? white : (Theme.dark_mode ? #ff6666 : #c62828);
                                    font-size: 16px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: 100%;
                                    height: 100%;
                                }

                                touch := TouchArea {
                                    clicked => {
                                        root.delete_user_preset(name);
                                    }
                                }
                            }
                        }
                        if (AppI18n.is-rtl): HorizontalLayout {
                            padding: 8px;
                            spacing: 8px;
                            Rectangle {
                                width: 32px;
                                height: 26px;
                                border-radius: 4px;
                                background: touch_rtl.pressed ? #c62828 : (touch_rtl.has-hover ? #ff4444 : transparent);
                                border-width: 0px;
                                Text {
                                    text: "\u{D7}";
                                    color: touch_rtl.has-hover ? white : (Theme.dark_mode ? #ff6666 : #c62828);
                                    font-size: 16px * LayoutConstants.font-scale;
                                    font-family: Theme.default_font;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: 100%;
                                    height: 100%;
                                }

                                touch_rtl := TouchArea {
                                    clicked => {
                                        root.delete_user_preset(name);
                                    }
                                }
                            }

                            CustomButton {
                                text: AppI18n.t("dialog.terminal.edit_preset", [AppI18n.version]);
                                height: 26px;
                                clicked => {
                                    root.edit_user_preset(name);
                                }
                            }

                            Text {
                                text: (idx + 1) + ". " + name;
                                font-size: 13px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_primary;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }
            }

            // Add/Edit form
            if root.show_user_preset_form: Rectangle {
                border-radius: 6px;
                background: Theme.input_bg;
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Text {
                        text: root.user_preset_form_title;
                        font-size: 14px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        font-weight: 600;
                        color: Theme.text_primary;
                    }

                    Text {
                        text: AppI18n.t("dialog.terminal.preset_name", [AppI18n.version]);
                        font-size: 12px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: Theme.text_secondary;
                    }

                    CustomLineEdit {
                        text <=> root.user_preset_form_name;
                        enabled: root.user_preset_original_name == "";
                        placeholder-text: "my-terminal";
                    }

                    Text {
                        text: AppI18n.t("dialog.terminal.custom_path", [AppI18n.version]);
                        font-size: 12px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: Theme.text_secondary;
                    }

                    if (!AppI18n.is-rtl): HorizontalLayout {
                        spacing: 6px;
                        CustomLineEdit {
                            text <=> root.user_preset_form_path;
                            horizontal-stretch: 1;
                            placeholder-text: "C:\\Windows\\system32\\cmd.exe";
                        }

                        CustomButton {
                            text: "...";
                            width: 40px;
                            height: 32px;
                            clicked => {
                                root.user_preset_path_browse();
                            }
                        }
                    }
                    if (AppI18n.is-rtl): HorizontalLayout {
                        spacing: 6px;
                        CustomButton {
                            text: "...";
                            width: 40px;
                            height: 32px;
                            clicked => {
                                root.user_preset_path_browse();
                            }
                        }

                        CustomLineEdit {
                            text <=> root.user_preset_form_path;
                            horizontal-stretch: 1;
                            placeholder-text: "C:\\Windows\\system32\\cmd.exe";
                        }
                    }
                    Text {
                        text: AppI18n.t("dialog.terminal.custom_args", [AppI18n.version]);
                        font-size: 12px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: Theme.text_secondary;
                    }

                    CustomLineEdit {
                        text <=> root.user_preset_form_args;
                        placeholder-text: "wsl -d {distro} --cd {dir}";
                    }

                    Text {
                        text: AppI18n.t("dialog.terminal.placeholders_hint", [AppI18n.version]);
                        font-size: 11px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: Theme.text_secondary;
                    }

                    if root.user_preset_form_error != "": Text {
                        text: root.user_preset_form_error;
                        font-size: 12px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: #ff3333;
                    }
                    if (!AppI18n.is-rtl): HorizontalLayout {
                        alignment: end;
                        spacing: 8px;
                        CustomButton {
                            text: AppI18n.t("dialog.cancel", [AppI18n.version]);
                            height: 32px;
                            clicked => {
                                root.cancel_user_preset_form();
                            }
                        }

                        CustomButton {
                            text: AppI18n.t("dialog.save", [AppI18n.version]);
                            primary: true;
                            height: 32px;
                            clicked => {
                                root.save_user_preset(
                                    root.user_preset_original_name,
                                    root.user_preset_form_name,
                                    root.user_preset_form_path,
                                    root.user_preset_form_args,
                                );
                            }
                        }
                    }
                    if (AppI18n.is-rtl): HorizontalLayout {
                        alignment: end;
                        spacing: 8px;
                        CustomButton {
                            text: AppI18n.t("dialog.save", [AppI18n.version]);
                            primary: true;
                            height: 32px;
                            clicked => {
                                root.save_user_preset(
                                    root.user_preset_original_name,
                                    root.user_preset_form_name,
                                    root.user_preset_form_path,
                                    root.user_preset_form_args,
                                );
                            }
                        }

                        CustomButton {
                            text: AppI18n.t("dialog.cancel", [AppI18n.version]);
                            height: 32px;
                            clicked => {
                                root.cancel_user_preset_form();
                            }
                        }
                    }
                }
            }
        }
    }
}

export component SidebarSettingsSection inherits Rectangle {
    in property <SettingsStrings> strings;
    in-out property <bool> sidebar_toggle: true;
    in-out property <bool> sidebar_add: true;
    in-out property <bool> sidebar_wsl_manage: true;
    in-out property <bool> sidebar_usb: true;
    in-out property <bool> sidebar_network: true;
    in-out property <bool> sidebar_about: true;
    background: Theme.card_bg;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.border_color;
    VerticalLayout {
        padding: 12px;
        spacing: 12px;
        Text {
            text: root.strings.sidebar_features;
            font-size: 13px * LayoutConstants.font-scale;
            font-family: Theme.default_font;
            color: Theme.text_secondary;
            horizontal-alignment: AppI18n.is-rtl ? right : left;
        }

        GridLayout {
            spacing: 12px;
            if (!AppI18n.is-rtl): Row {
                CustomCheckBox {
                    text: AppI18n.t("sidebar.toggle", [AppI18n.version]);
                    checked <=> root.sidebar_toggle;
                    horizontal-stretch: 1;
                }

                CustomCheckBox {
                    text: AppI18n.t("sidebar.home", [AppI18n.version]);
                    checked: true;
                    enabled: false;
                    horizontal-stretch: 1;
                }

                CustomCheckBox {
                    text: AppI18n.t("sidebar.add", [AppI18n.version]);
                    checked <=> root.sidebar_add;
                    horizontal-stretch: 1;
                }
            }
            if (AppI18n.is-rtl): Row {
                CustomCheckBox {
                    text: AppI18n.t("sidebar.add", [AppI18n.version]);
                    checked <=> root.sidebar_add;
                    horizontal-stretch: 1;
                }

                CustomCheckBox {
                    text: AppI18n.t("sidebar.home", [AppI18n.version]);
                    checked: true;
                    enabled: false;
                    horizontal-stretch: 1;
                }

                CustomCheckBox {
                    text: AppI18n.t("sidebar.toggle", [AppI18n.version]);
                    checked <=> root.sidebar_toggle;
                    horizontal-stretch: 1;
                }
            }

            if (!AppI18n.is-rtl): Row {
                CustomCheckBox {
                    text: AppI18n.t("sidebar.usb", [AppI18n.version]);
                    checked <=> root.sidebar_usb;
                    horizontal-stretch: 1;
                }

                CustomCheckBox {
                    text: AppI18n.t("sidebar.network", [AppI18n.version]);
                    checked <=> root.sidebar_network;
                    horizontal-stretch: 1;
                }

                Rectangle {
                    horizontal-stretch: 1;
                }
            }
            if (AppI18n.is-rtl): Row {
                Rectangle {
                    horizontal-stretch: 1;
                }

                CustomCheckBox {
                    text: AppI18n.t("sidebar.network", [AppI18n.version]);
                    checked <=> root.sidebar_network;
                    horizontal-stretch: 1;
                }

                CustomCheckBox {
                    text: AppI18n.t("sidebar.usb", [AppI18n.version]);
                    checked <=> root.sidebar_usb;
                    horizontal-stretch: 1;
                }
            }

            if (!AppI18n.is-rtl): Row {
                CustomCheckBox {
                    text: AppI18n.t("sidebar.wsl_manage", [AppI18n.version]);
                    checked <=> root.sidebar_wsl_manage;
                    horizontal-stretch: 1;
                }

                CustomCheckBox {
                    text: AppI18n.t("sidebar.settings", [AppI18n.version]);
                    checked: true;
                    enabled: false;
                    horizontal-stretch: 1;
                }

                CustomCheckBox {
                    text: AppI18n.t("sidebar.about", [AppI18n.version]);
                    checked <=> root.sidebar_about;
                    horizontal-stretch: 1;
                }
            }
            if (AppI18n.is-rtl): Row {
                CustomCheckBox {
                    text: AppI18n.t("sidebar.about", [AppI18n.version]);
                    checked <=> root.sidebar_about;
                    horizontal-stretch: 1;
                }

                CustomCheckBox {
                    text: AppI18n.t("sidebar.settings", [AppI18n.version]);
                    checked: true;
                    enabled: false;
                    horizontal-stretch: 1;
                }

                CustomCheckBox {
                    text: AppI18n.t("sidebar.wsl_manage", [AppI18n.version]);
                    checked <=> root.sidebar_wsl_manage;
                    horizontal-stretch: 1;
                }
            }
        }
    }
}
