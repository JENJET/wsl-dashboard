import { Theme, AppI18n, SettingsStrings, LayoutConstants } from "../../theme.slint";
import { CustomScrollbar } from "../../components/scrollbar.slint";
import { 
    CustomCheckBox, 
    CustomButton,
    CustomComboBox
} from "../../components/form_widgets.slint";
import { 
    GeneralSettingsSection, 
    PathSettingsSection, 
    TerminalSettingsSection, 
    SidebarSettingsSection 
} from "sections.slint";

// Settings Tab component matching NetworkTab style
component SettingsTab inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    callback clicked;

    width: tab-label.preferred-width + 24px;
    height: 32px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
    background: active ? Theme.accent.with-alpha(0.12) : (touch.has-hover ? Theme.hover_bg : Theme.background);
    animate background { duration: 150ms; }

    tab-label := Text {
        text: root.text;
        color: active ? Theme.accent : Theme.text_secondary;
        font-size: 13px * LayoutConstants.font-scale;
        font-weight: 400;
        font-family: Theme.default_font;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: 150ms; }
    }

    if active: Rectangle {
        y: parent.height - 2px;
        height: 2px;
        width: parent.width * 0.6;
        x: (parent.width - self.width) / 2;
        background: Theme.accent;
        border-radius: 1px;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component SettingsView inherits Rectangle {
    in-out property <string> ui_language: "auto";
    in-out property <string> distro_location: "";
    in-out property <string> logs_location: "";
    in-out property <int> log_level: 4;
    in-out property <int> log_days: 7;
    in-out property <int> check_update_interval: 7;
    in property <[string]> terminal_emulator_options: [];
    in property <[bool]> terminal_emulator_disabled: [];
    in-out property <int> terminal_emulator_index: 0;
    in-out property <bool> terminal_show_custom: false;
    in-out property <string> terminal_custom_path: "";
    in-out property <string> terminal_custom_args: "";
    in property <string> terminal_validation_result: "";
    in property <bool> terminal_validation_ok: false;
    in property <[string]> terminal_user_preset_names: [];
    in property <string> terminal_user_preset_form_title: "";
    in-out property <bool> terminal_show_user_preset_form: false;
    in-out property <string> terminal_user_preset_form_name: "";
    in-out property <string> terminal_user_preset_form_path: "";
    in-out property <string> terminal_user_preset_form_args: "";
    in property <string> terminal_user_preset_form_error: "";
    in-out property <string> terminal_user_preset_original_name: "";
    callback edit_user_preset(string);
    callback delete_user_preset(string);
    callback save_user_preset(string, string, string, string);
    callback cancel_user_preset_form;
    callback add_user_preset;
    callback user_preset_path_browse;
    in-out property <bool> system_color: false;
    in-out property <bool> auto_shutdown: false;
    in-out property <bool> tray_autostart: false;
    in-out property <bool> tray_start_minimized: false;
    in-out property <bool> tray_close_to_tray: true;
    in-out property <bool> sidebar_toggle: true;
    in-out property <bool> sidebar_add: true;
    in-out property <bool> sidebar_wsl_manage: true;
    in-out property <bool> sidebar_usb: true;
    in-out property <bool> sidebar_network: true;
    in-out property <bool> sidebar_about: true;
    in-out property <bool> settings_auto_save: false;
    in property <SettingsStrings> strings;

    // Tab selection
    in-out property <int> selected_tab: 0;

    // Options Models
    private property <[string]> language-options: [
        AppI18n.t("settings.languages.auto", [AppI18n.version]), AppI18n.t("settings.languages.en", [AppI18n.version]),
        AppI18n.t("settings.languages.zh_cn", [AppI18n.version]), AppI18n.t("settings.languages.zh_tw", [AppI18n.version]),
        AppI18n.t("settings.languages.hi", [AppI18n.version]), AppI18n.t("settings.languages.es", [AppI18n.version]),
        AppI18n.t("settings.languages.fr", [AppI18n.version]), AppI18n.t("settings.languages.ar", [AppI18n.version]),
        AppI18n.t("settings.languages.bn", [AppI18n.version]), AppI18n.t("settings.languages.pt", [AppI18n.version]),
        AppI18n.t("settings.languages.ru", [AppI18n.version]), AppI18n.t("settings.languages.ur", [AppI18n.version]),
        AppI18n.t("settings.languages.id", [AppI18n.version]), AppI18n.t("settings.languages.de", [AppI18n.version]),
        AppI18n.t("settings.languages.ja", [AppI18n.version]), AppI18n.t("settings.languages.tr", [AppI18n.version]),
        AppI18n.t("settings.languages.ko", [AppI18n.version]), AppI18n.t("settings.languages.it", [AppI18n.version]),
        AppI18n.t("settings.languages.nl", [AppI18n.version]), AppI18n.t("settings.languages.sv", [AppI18n.version]),
        AppI18n.t("settings.languages.cs", [AppI18n.version]), AppI18n.t("settings.languages.el", [AppI18n.version]),
        AppI18n.t("settings.languages.hu", [AppI18n.version]), AppI18n.t("settings.languages.he", [AppI18n.version]),
        AppI18n.t("settings.languages.no", [AppI18n.version]), AppI18n.t("settings.languages.da", [AppI18n.version]),
        AppI18n.t("settings.languages.fi", [AppI18n.version]), AppI18n.t("settings.languages.sk", [AppI18n.version]),
        AppI18n.t("settings.languages.sl", [AppI18n.version]), AppI18n.t("settings.languages.is", [AppI18n.version])
    ];
    private property <[string]> log-level-options: [
        AppI18n.t("settings.log_levels.error", [AppI18n.version]), AppI18n.t("settings.log_levels.warn", [AppI18n.version]),
        AppI18n.t("settings.log_levels.info", [AppI18n.version]), AppI18n.t("settings.log_levels.debug", [AppI18n.version]),
        AppI18n.t("settings.log_levels.trace", [AppI18n.version])
    ];
    private property <[string]> log-days-options: [
        AppI18n.t("settings.log_retention_options.seven_days", [AppI18n.version]),
        AppI18n.t("settings.log_retention_options.half_month", [AppI18n.version]),
        AppI18n.t("settings.log_retention_options.one_month", [AppI18n.version])
    ];
    private property <[string]> check-update-options: [
        AppI18n.t("settings.update_options.daily", [AppI18n.version]), AppI18n.t("settings.update_options.weekly", [AppI18n.version]),
        AppI18n.t("settings.update_options.biweekly", [AppI18n.version]), AppI18n.t("settings.update_options.monthly", [AppI18n.version])
    ];

    // Selected Indices
    property <int> selected-language-index: get-language-index(ui_language);
    property <int> selected-log-level-index: get-log-level-index(log_level);
    property <int> selected-check-update-index: get-check-update-index(check_update_interval);
    property <int> selected-log-days-index: get-log-days-index(log_days);

    // Sync back indices to properties
    changed selected-language-index => {
        ui_language = index-to-lang(selected-language-index);
        if (root.settings_auto_save) { root.save-settings(); }
    }
    changed selected-log-level-index => {
        log_level = selected-log-level-index + 1;
        if (root.settings_auto_save) { root.save-settings(); }
    }
    changed selected-check-update-index => {
        if (selected-check-update-index == 0) { check_update_interval = 1; }
        else if (selected-check-update-index == 1) { check_update_interval = 7; }
        else if (selected-check-update-index == 2) { check_update_interval = 15; }
        else if (selected-check-update-index == 3) { check_update_interval = 30; }
        if (root.settings_auto_save) { root.save-settings(); }
    }
    changed selected-log-days-index => {
        if (selected-log-days-index == 0) { log_days = 7; }
        else if (selected-log-days-index == 1) { log_days = 15; }
        else if (selected-log-days-index == 2) { log_days = 30; }
        if (root.settings_auto_save) { root.save-settings(); }
    }

    // Auto-save on property changes (guarded to skip initialization)
    changed distro_location => { if (root.settings_auto_save) { root.save-settings(); } }
    changed logs_location => { if (root.settings_auto_save) { root.save-settings(); } }
    changed terminal_emulator_index => { if (root.settings_auto_save) { root.save-settings(); } }
    changed terminal_show_custom => { if (root.settings_auto_save) { root.save-settings(); } }
    changed terminal_custom_path => { if (root.settings_auto_save) { root.save-settings(); } }
    changed terminal_custom_args => { if (root.settings_auto_save) { root.save-settings(); } }
    changed system_color => { if (root.settings_auto_save) { root.save-settings(); } }
    changed auto_shutdown => { if (root.settings_auto_save) { root.save-settings(); } }
    changed tray_autostart => { if (root.settings_auto_save) { root.save-settings(); } }
    changed tray_start_minimized => { if (root.settings_auto_save) { root.save-settings(); } }
    changed tray_close_to_tray => { if (root.settings_auto_save) { root.save-settings(); } }
    changed sidebar_toggle => { if (root.settings_auto_save) { root.save-settings(); } }
    changed sidebar_add => { if (root.settings_auto_save) { root.save-settings(); } }
    changed sidebar_wsl_manage => { if (root.settings_auto_save) { root.save-settings(); } }
    changed sidebar_usb => { if (root.settings_auto_save) { root.save-settings(); } }
    changed sidebar_network => { if (root.settings_auto_save) { root.save-settings(); } }
    changed sidebar_about => { if (root.settings_auto_save) { root.save-settings(); } }

    pure function get-language-index(lang: string) -> int {
        if (lang == "en") { return 1; }
        if (lang == "zh-CN") { return 2; }
        if (lang == "zh-TW") { return 3; }
        if (lang == "hi") { return 4; }
        if (lang == "es") { return 5; }
        if (lang == "fr") { return 6; }
        if (lang == "ar") { return 7; }
        if (lang == "bn") { return 8; }
        if (lang == "pt") { return 9; }
        if (lang == "ru") { return 10; }
        if (lang == "ur") { return 11; }
        if (lang == "id") { return 12; }
        if (lang == "de") { return 13; }
        if (lang == "ja") { return 14; }
        if (lang == "tr") { return 15; }
        if (lang == "ko") { return 16; }
        if (lang == "it") { return 17; }
        if (lang == "nl") { return 18; }
        if (lang == "sv") { return 19; }
        if (lang == "cs") { return 20; }
        if (lang == "el") { return 21; }
        if (lang == "hu") { return 22; }
        if (lang == "he") { return 23; }
        if (lang == "no") { return 24; }
        if (lang == "da") { return 25; }
        if (lang == "fi") { return 26; }
        if (lang == "sk") { return 27; }
        if (lang == "sl") { return 28; }
        if (lang == "is") { return 29; }
        return 0; // auto
    }

    pure function index-to-lang(idx: int) -> string {
        if (idx == 1) { return "en"; }
        if (idx == 2) { return "zh-CN"; }
        if (idx == 3) { return "zh-TW"; }
        if (idx == 4) { return "hi"; }
        if (idx == 5) { return "es"; }
        if (idx == 6) { return "fr"; }
        if (idx == 7) { return "ar"; }
        if (idx == 8) { return "bn"; }
        if (idx == 9) { return "pt"; }
        if (idx == 10) { return "ru"; }
        if (idx == 11) { return "ur"; }
        if (idx == 12) { return "id"; }
        if (idx == 13) { return "de"; }
        if (idx == 14) { return "ja"; }
        if (idx == 15) { return "tr"; }
        if (idx == 16) { return "ko"; }
        if (idx == 17) { return "it"; }
        if (idx == 18) { return "nl"; }
        if (idx == 19) { return "sv"; }
        if (idx == 20) { return "cs"; }
        if (idx == 21) { return "el"; }
        if (idx == 22) { return "hu"; }
        if (idx == 23) { return "he"; }
        if (idx == 24) { return "no"; }
        if (idx == 25) { return "da"; }
        if (idx == 26) { return "fi"; }
        if (idx == 27) { return "sk"; }
        if (idx == 28) { return "sl"; }
        if (idx == 29) { return "is"; }
        return "auto";
    }

    pure function get-log-level-index(level: int) -> int {
        if (level >= 1 && level <= 5) { return level - 1; }
        return 2;
    }
    pure function get-check-update-index(interval: int) -> int {
        if (interval == 1) { return 0; }
        if (interval == 7) { return 1; }
        if (interval == 15) { return 2; }
        if (interval == 30) { return 3; }
        return 1;
    }
    pure function get-log-days-index(days: int) -> int {
        if (days == 30) { return 2; }
        if (days == 15) { return 1; }
        return 0;
    }

    callback save-settings();
    callback select-distro-folder();
    callback select-logs-folder();
    callback open-wsl-settings();
    callback terminal-path-browse();
    callback terminal-refresh-terminals();

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Tab Bar
        HorizontalLayout {
            height: 40px;
            padding-left: 4px;
            padding-right: 8px;
            spacing: 4px;
            alignment: AppI18n.is-rtl ? end : start;

            if (AppI18n.is-rtl): SettingsTab {
                text: root.strings.tab_interface;
                active: root.selected_tab == 2;
                clicked => { root.selected_tab = 2; }
            }
            if (AppI18n.is-rtl): SettingsTab {
                text: root.strings.tab_advanced;
                active: root.selected_tab == 1;
                clicked => { root.selected_tab = 1; }
            }
            if (AppI18n.is-rtl): SettingsTab {
                text: root.strings.tab_general;
                active: root.selected_tab == 0;
                clicked => { root.selected_tab = 0; }
            }

            if (!AppI18n.is-rtl): SettingsTab {
                text: root.strings.tab_general;
                active: root.selected_tab == 0;
                clicked => { root.selected_tab = 0; }
            }
            if (!AppI18n.is-rtl): SettingsTab {
                text: root.strings.tab_advanced;
                active: root.selected_tab == 1;
                clicked => { root.selected_tab = 1; }
            }
            if (!AppI18n.is-rtl): SettingsTab {
                text: root.strings.tab_interface;
                active: root.selected_tab == 2;
                clicked => { root.selected_tab = 2; }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.border_color;
        }

        // Tab Content
        Rectangle {
            vertical-stretch: 1;

            // General Tab
            if (root.selected_tab == 0): Rectangle {
                width: 100%;
                height: 100%;
                clip: true;
                general-flickable := Flickable {
                    viewport-height: general-content.preferred-height;
                    width: parent.width;
                    height: 100%;
                    general-content := VerticalLayout {
                        padding-left: AppI18n.is-rtl ? 16px : 4px;
                        padding-right: AppI18n.is-rtl ? 4px : 16px;
                        padding-top: 12px;
                        padding-bottom: 4px;
                        spacing: 12px;
                        alignment: start;

                        GeneralSettingsSection {
                            strings: root.strings;
                            selected_language_index <=> root.selected-language-index;
                            selected_check_update_index <=> root.selected-check-update-index;
                            language_options: root.language-options;
                            check_update_options: root.check-update-options;
                        }

                        Rectangle {
                            height: 1px;
                            background: Theme.border_color;
                        }

                        Rectangle {
                            background: Theme.card_bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.border_color;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 12px;
                                CustomCheckBox { checked <=> root.tray_autostart; text: root.strings.auto_start; }
                                CustomCheckBox { checked <=> root.tray_start_minimized; text: root.strings.minimize_tray; }
                                CustomCheckBox { checked <=> root.tray_close_to_tray; text: root.strings.close_to_tray; }
                            }
                        }

                        Rectangle {
                            height: 1px;
                            background: Theme.border_color;
                        }

                        Rectangle {
                            background: Theme.card_bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.border_color;
                            VerticalLayout {
                                padding: 12px;
                                spacing: 12px;
                                CustomCheckBox { checked <=> root.auto_shutdown; text: root.strings.auto_close; }
                            }
                        }
                    }
                }
                if (general-flickable.viewport-height > general-flickable.height): CustomScrollbar {
                    x: AppI18n.is-rtl ? 4px : parent.width - 10px;
                    y: 0; width: 8px; height: 100%;
                    maximum: general-flickable.viewport-height - general-flickable.height;
                    page_size: general-flickable.height;
                    value: -general-flickable.viewport-y;
                    scroll_to(v) => { general-flickable.viewport-y = -v; }
                }
            }

            // Advanced Tab
            if (root.selected_tab == 1): Rectangle {
                width: 100%;
                height: 100%;
                clip: true;
                advanced-flickable := Flickable {
                    viewport-height: advanced-content.preferred-height;
                    width: parent.width;
                    height: 100%;
                    advanced-content := VerticalLayout {
                        padding-left: AppI18n.is-rtl ? 16px : 4px;
                        padding-right: AppI18n.is-rtl ? 4px : 16px;
                        padding-top: 12px;
                        padding-bottom: 4px;
                        spacing: 12px;
                        alignment: start;

                        TerminalSettingsSection {
                            strings: root.strings;
                            emulator_options: root.terminal_emulator_options;
                            emulator_disabled: root.terminal_emulator_disabled;
                            selected_emulator_index <=> root.terminal_emulator_index;
                            show_custom <=> root.terminal_show_custom;
                            custom_path <=> root.terminal_custom_path;
                            custom_args <=> root.terminal_custom_args;
                            validation_result: root.terminal_validation_result;
                            validation_ok: root.terminal_validation_ok;
                            path_browse => { root.terminal-path-browse(); }
                            refresh_terminals => { root.terminal-refresh-terminals(); }
                            user_preset_names: root.terminal_user_preset_names;
                            user_preset_form_title: root.terminal_user_preset_form_title;
                            show_user_preset_form <=> root.terminal_show_user_preset_form;
                            user_preset_form_name <=> root.terminal_user_preset_form_name;
                            user_preset_form_path <=> root.terminal_user_preset_form_path;
                            user_preset_form_args <=> root.terminal_user_preset_form_args;
                            user_preset_form_error: root.terminal_user_preset_form_error;
                            user_preset_original_name <=> root.terminal_user_preset_original_name;
                            edit_user_preset(name) => { root.edit_user_preset(name); }
                            delete_user_preset(name) => { root.delete_user_preset(name); }
                            save_user_preset(old, name, path, args) => { root.save_user_preset(old, name, path, args); }
                            cancel_user_preset_form => { root.cancel_user_preset_form(); }
                            add_user_preset => { root.add_user_preset(); }
                            user_preset_path_browse => { root.user_preset_path_browse(); }
                        }

                        Rectangle {
                            height: 1px;
                            background: Theme.border_color;
                        }

                        PathSettingsSection {
                            strings: root.strings;
                            distro_location <=> root.distro_location;
                            logs_location <=> root.logs_location;
                            select_distro_folder => { root.select-distro-folder(); }
                            select_logs_folder => { root.select-logs-folder(); }
                        }

                        Rectangle {
                            height: 1px;
                            background: Theme.border_color;
                        }

                        Rectangle {
                            z: 40;
                            height: log-grid.preferred-height;
                            log-grid := GridLayout {
                                spacing: 12px;
                                Row {
                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        preferred-width: 0;
                                        min-width: 0;
                                        spacing: 10px;
                                        Text {
                                            text: root.strings.log_level;
                                            font-size: 13px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            color: Theme.text_secondary;
                                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                                        }
                                        CustomComboBox {
                                            model: root.log-level-options;
                                            current-index <=> root.selected-log-level-index;
                                            height: 32px;
                                            dropdown-height: 130px;
                                        }
                                    }
                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        preferred-width: 0;
                                        min-width: 0;
                                        spacing: 10px;
                                        Text {
                                            text: root.strings.log_retention;
                                            font-size: 13px * LayoutConstants.font-scale;
                                            font-family: Theme.default_font;
                                            color: Theme.text_secondary;
                                            horizontal-alignment: AppI18n.is-rtl ? right : left;
                                        }
                                        CustomComboBox {
                                            model: root.log-days-options;
                                            current-index <=> root.selected-log-days-index;
                                            height: 32px;
                                            dropdown-height: 100px;
                                        }
                                    }
                                }
                            }
                        }

                    }
                }
                if (advanced-flickable.viewport-height > advanced-flickable.height): CustomScrollbar {
                    x: AppI18n.is-rtl ? 4px : parent.width - 10px;
                    y: 0; width: 8px; height: 100%;
                    maximum: advanced-flickable.viewport-height - advanced-flickable.height;
                    page_size: advanced-flickable.height;
                    value: -advanced-flickable.viewport-y;
                    scroll_to(v) => { advanced-flickable.viewport-y = -v; }
                }
            }

            // Interface Tab
            if (root.selected_tab == 2): Rectangle {
                width: 100%;
                height: 100%;
                clip: true;
                interface-flickable := Flickable {
                    viewport-height: interface-content.preferred-height;
                    width: parent.width;
                    height: 100%;
                    interface-content := VerticalLayout {
                        padding-left: AppI18n.is-rtl ? 16px : 4px;
                        padding-right: AppI18n.is-rtl ? 4px : 16px;
                        padding-top: 12px;
                        padding-bottom: 4px;
                        spacing: 12px;
                        alignment: start;

                        SidebarSettingsSection {
                            strings: root.strings;
                            sidebar_toggle <=> root.sidebar_toggle;
                            sidebar_add <=> root.sidebar_add;
                            sidebar_wsl_manage <=> root.sidebar_wsl_manage;
                            sidebar_usb <=> root.sidebar_usb;
                            sidebar_network <=> root.sidebar_network;
                            sidebar_about <=> root.sidebar_about;
                        }

                        Rectangle {
                            height: 1px;
                            background: Theme.border_color;
                        }

                        Rectangle {
                            background: Theme.card_bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.border_color;
                            VerticalLayout {
                                padding: 12px;
                                spacing: 12px;
                                CustomCheckBox { checked <=> root.system_color; text: root.strings.system_color; }
                            }
                        }
                    }
                }
                if (interface-flickable.viewport-height > interface-flickable.height): CustomScrollbar {
                    x: AppI18n.is-rtl ? 4px : parent.width - 10px;
                    y: 0; width: 8px; height: 100%;
                    maximum: interface-flickable.viewport-height - interface-flickable.height;
                    page_size: interface-flickable.height;
                    value: -interface-flickable.viewport-y;
                    scroll_to(v) => { interface-flickable.viewport-y = -v; }
                }
            }
        }

        // Bottom Buttons (save is auto-save now, show WSL Settings only)
        HorizontalLayout {
            padding-left: AppI18n.is-rtl ? 16px : 4px;
            padding-right: AppI18n.is-rtl ? 4px : 16px;
            padding-top: 4px;
            padding-bottom: 4px;
            spacing: 8px;
            if (!AppI18n.is-rtl): CustomButton {
                text: root.strings.wsl_settings; height: 32px;
                clicked => { root.open-wsl-settings(); }
            }
            Rectangle { horizontal-stretch: 1; }
            if (AppI18n.is-rtl): CustomButton {
                text: root.strings.wsl_settings; height: 32px;
                clicked => { root.open-wsl-settings(); }
            }
        }
    }
}
